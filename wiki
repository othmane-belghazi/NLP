# ─────────────────────────────────────────────────────────────────────────────

feature_cols = [
    "prime_proposee", "bonus_malus", "cumul_majoration_totale_pct",
    "nb_annees_hausse_consecutive", "score_pression_tarifaire",
    "franchissement_centaine", "ecart_premiere_derniere_pct",
    "anciennete_portefeuille", "volatilite_tarifaire",
    "age_conducteur", "nb_sinistres"
]

X = df[feature_cols].fillna(0).copy()
scaler = StandardScaler()
X_scaled = scaler.fit_transform(X)

# Méthode du coude pour k optimal
inertias = []
sil_scores = []
K_range = range(2, 9)
for k in K_range:
    km = KMeans(n_clusters=k, random_state=42, n_init=10, max_iter=300)
    labels = km.fit_predict(X_scaled)
    inertias.append(km.inertia_)
    sil_scores.append(silhouette_score(X_scaled, labels))

# Choix k=4 (ajustable)
K_OPTIMAL = 4
kmeans_final = KMeans(n_clusters=K_OPTIMAL, random_state=42, n_init=20, max_iter=500)
df["cluster"] = kmeans_final.fit_predict(X_scaled)

# PCA pour visualisation
pca = PCA(n_components=2)
X_pca = pca.fit_transform(X_scaled)
df["pca_1"] = X_pca[:, 0]
df["pca_2"] = X_pca[:, 1]

print(f"\n── Clustering K={K_OPTIMAL} ──")
print(f"Silhouette Score: {silhouette_score(X_scaled, df['cluster']):.3f}")
print(f"Variance expliquée PCA: {pca.explained_variance_ratio_.sum()*100:.1f}%")

# Profils des clusters
cluster_profiles = df.groupby("cluster").agg(
    nb_clients=("id_client", "count"),
    prime_moy=("prime_proposee", "mean"),
    bm_moyen=("bonus_malus", "mean"),
    cumul_majo_pct=("cumul_majoration_totale_pct", "mean"),
    hausse_consec=("nb_annees_hausse_consecutive", "mean"),
    pression_tarif=("score_pression_tarifaire", "mean"),
    taux_franchissement=("franchissement_centaine", "mean"),
    ecart_1ere_derniere=("ecart_premiere_derniere_pct", "mean"),
    anciennete=("anciennete_portefeuille", "mean"),
    age_moyen=("age_conducteur", "mean"),
    sinistres_moy=("nb_sinistres", "mean"),
    taux_nouveau=("is_nouveau_client", "mean"),
    volatilite_moy=("volatilite_tarifaire", "mean"),
).round(2)

# Nommer les clusters
cluster_names = {}
used_names = set()
for c in range(K_OPTIMAL):
    row = cluster_profiles.loc[c]
    if row["taux_nouveau"] > 0.5 and "Nouveaux Clients" not in used_names:
        name = "Nouveaux Clients"
    elif row["bm_moyen"] > 1.2 and "Hauts Risques / Malussés" not in used_names:
        name = "Hauts Risques / Malussés"
    elif row["pression_tarif"] > cluster_profiles["pression_tarif"].median() and row["taux_franchissement"] > 0.3 and "Choc Tarifaire (seuil)" not in used_names:
        name = "Choc Tarifaire (seuil)"
    elif row["hausse_consec"] >= 2 and "Érosion Progressive" not in used_names:
        name = "Érosion Progressive"
    elif row["prime_moy"] < cluster_profiles["prime_moy"].median() and "Sensibles au Prix" not in used_names:
        name = "Sensibles au Prix"
    else:
        candidates = ["Fidèles Déçus", "Surprimés Récurrents", "Profils Mixtes"]
        name = next((n for n in candidates if n not in used_names), f"Segment {c}")
    cluster_names[c] = name
    used_names.add(name)

df["cluster_nom"] = df["cluster"].map(cluster_names)
cluster_profiles["nom_cluster"] = cluster_profiles.index.map(cluster_names)

