# ─── G02  Analyse tarifaire ────────────────────────────────────────────────────
def g02_analyse_tarifaire(df):
    fig, axes = plt.subplots(2, 3, figsize=(20, 12))
    fig.suptitle("Analyse Tarifaire — Impact de la Variation de Prime sur la Résiliation")

    # A. Taux résiliation par catégorie de variation
    ax = axes[0,0]
    agg = df.groupby('cat_variation', observed=True)['resilie'].agg(['mean','count']).reset_index()
    agg['taux'] = agg['mean']*100
    colors = [BLEU if ('Baisse' in str(c) or 'Stable' in str(c)) else ROUGE
              for c in agg['cat_variation']]
    bars = ax.bar(range(len(agg)), agg['taux'], color=colors,
                  width=0.65, alpha=0.85, edgecolor=BG)
    ax.set_xticks(range(len(agg)))
    ax.set_xticklabels(agg['cat_variation'], rotation=40, ha='right', fontsize=8)
    ax.set_title("Taux résiliation\npar tranche de variation"); ax.set_ylabel("Taux (%)")
    ax_clean(ax); ax.grid(axis='y', alpha=0.35)
    annotate_bars(ax, bars, agg['taux'])

    # B. Courbe continue var_rel_prime vs taux
    ax = axes[0,1]
    d = df[df['var_rel_prime'].notna()].copy()
    d['bin'] = pd.cut(d['var_rel_prime'], bins=np.arange(-30, 55, 3))
    c2 = d.groupby('bin', observed=False)['resilie'].agg(['mean','count']).reset_index()
    c2['taux'] = c2['mean']*100
    c2['mid']  = c2['bin'].apply(lambda x: x.mid if pd.notna(x) else np.nan)
    c2 = c2.dropna(subset=['mid'])
    c2 = c2[c2['count'] > 30]
    ax.fill_between(c2['mid'], c2['taux'], alpha=0.2, color=ROUGE)
    ax.plot(c2['mid'], c2['taux'], color=ROUGE, lw=2.5, marker='o', markersize=4)
    ax.axvline(0, color=JAUNE, ls='--', lw=1.8, alpha=0.7, label='Δ = 0')
    ax.axvline(8, color=ORANGE, ls=':', lw=1.5, alpha=0.7, label='Seuil +8%')
    ax.axvline(15, color=ROUGE, ls=':', lw=1.5, alpha=0.7, label='Seuil +15%')
    ax.set_title("Courbe de sensibilité\nvariation prime → résiliation"); ax.set_xlabel("Var. relative (%)"); ax.set_ylabel("Taux (%)")
    ax.legend(fontsize=8); ax_clean(ax); ax.grid(alpha=0.35)

    # C. Variation par segment (boxplot)
    ax = axes[0,2]
    segs = sorted(df['segment'].dropna().unique())
    data_bp = [df[(df['segment']==s)&(df['var_rel_prime'].notna())]['var_rel_prime'].clip(-30,50).values
               for s in segs]
    bp = ax.boxplot(data_bp, patch_artist=True, notch=False,
                    medianprops=dict(color='white', lw=2.2),
                    flierprops=dict(marker='.', color=TXT2, alpha=0.2, ms=2))
    for box, c in zip(bp['boxes'], PAL): box.set_facecolor(c); box.set_alpha(0.75)
    for w in bp['whiskers']: w.set_color(TXT2)
    for c in bp['caps']:     c.set_color(TXT2)
    ax.set_xticks(range(1, len(segs)+1)); ax.set_xticklabels(segs)
    ax.axhline(0, color=JAUNE, ls='--', lw=1.5, alpha=0.6)
    ax.set_title("Distribution variation prime\npar segment"); ax.set_ylabel("Var. relative (%)")
    ax_clean(ax); ax.grid(axis='y', alpha=0.35)

    # D. Franchissements de seuils
    ax = axes[1,0]
    seuils = [('franchit_1000','Seuil 1 000 €'),
              ('franchit_1500','Seuil 1 500 €'),
              ('franchit_2000','Seuil 2 000 €')]
    tx_base = df['resilie'].mean()*100
    ecarts, lbls_s, cols_s = [], [], []
    for var, lbl in seuils:
        if df[var].sum() > 10:
            tx_oui = df[df[var]==1]['resilie'].mean()*100
            ecarts.append(tx_oui - tx_base)
            lbls_s.append(lbl)
            cols_s.append(ROUGE if (tx_oui - tx_base) > 0 else VERT)
    if ecarts:
        y_pos = range(len(lbls_s))
        bars_s = ax.barh(y_pos, ecarts, color=cols_s, height=0.45, alpha=0.85)
        ax.axvline(0, color=JAUNE, lw=1.5, alpha=0.7)
        ax.set_yticks(y_pos); ax.set_yticklabels(lbls_s)
        ax.set_xlabel("Écart au taux moyen (pp)")
        ax.set_title(f"Surcroît de résiliation\nlors du franchissement de seuil\n(base : {tx_base:.1f}%)")
        for bar, val in zip(bars_s, ecarts):
            sign = '+' if val >= 0 else ''
            ax.text(val + (0.1 if val >= 0 else -0.1), bar.get_y()+bar.get_height()/2,
                    f'{sign}{val:.1f}pp', va='center',
                    ha='left' if val >= 0 else 'right',
                    fontsize=10, fontweight='bold', color=ROUGE if val > 0 else VERT)
        ax_clean(ax); ax.grid(axis='x', alpha=0.35)

    # E. Scatter prime_comm_prec vs prime_comm coloré par résiliation
    ax = axes[1,1]
    s = df.sample(min(5000, len(df)), random_state=42)
    for val, lbl, c, a in [(0,'Actif',BLEU,0.25),(1,'Résilié',ROUGE,0.55)]:
        sub = s[s['resilie']==val]
        ax.scatter(sub['prime_comm_prec'], sub['prime_comm'],
                   c=c, alpha=a, s=12, label=lbl, edgecolors='none')
    lim = [df['prime_comm'].quantile(0.01), df['prime_comm'].quantile(0.98)]
    ax.plot(lim, lim, color=JAUNE, ls='--', lw=1.5, alpha=0.6, label='Δ = 0')
    ax.set_title("Prime précédente vs courante\n(résiliés vs actifs)")
    ax.set_xlabel("Prime précédente (€)"); ax.set_ylabel("Prime courante (€)")
    ax.legend(fontsize=9, markerscale=3); ax_clean(ax); ax.grid(alpha=0.3)

    # F. Taux résiliation par tranche de prime
    ax = axes[1,2]
    agg3 = df.groupby('tranche_prime', observed=True)['resilie'].agg(['mean','count']).reset_index()
    agg3['taux'] = agg3['mean']*100
    cg = plt.cm.RdYlGn_r(np.linspace(0.1, 0.9, len(agg3)))
    bars3 = ax.bar(agg3['tranche_prime'].astype(str), agg3['taux'],
                   color=cg, width=0.65, alpha=0.88)
    annotate_bars(ax, bars3, agg3['taux'], color='white')
    ax.set_title("Taux résiliation\npar tranche de prime courante")
    ax.set_ylabel("Taux (%)"); ax.tick_params(axis='x', rotation=35)
    ax_clean(ax); ax.grid(axis='y', alpha=0.35)

    plt.tight_layout()
    sauvegarder(fig, "02_analyse_tarifaire.png")

# ─── G03  Effet cumul inter-annuel ───────────────────────────────────────────
def g03_effet_cumul(df):
    fig, axes = plt.subplots(2, 2, figsize=(18, 13))
    fig.suptitle("Effet Cumul des Majorations — Analyse Inter-Annuelle")

    df_multi = df[df['multi_annees']==1].copy()

    # A. Taux résiliation selon cumul hausse historique
    ax = axes[0,0]
    agg = df_multi.groupby('cat_cumul', observed=True)['resilie'].agg(['mean','count']).reset_index()
    agg['taux'] = agg['mean']*100
    cg = plt.cm.RdYlGn_r(np.linspace(0.1, 0.9, len(agg)))
    bars = ax.bar(range(len(agg)), agg['taux'], color=cg, width=0.62, alpha=0.88)
    ax.set_xticks(range(len(agg)))
    ax.set_xticklabels(agg['cat_cumul'], rotation=35, ha='right', fontsize=8.5)
    ax.set_title("Taux résiliation\nselon le cumul de hausses inter-annuelles")
    ax.set_ylabel("Taux (%)"); ax_clean(ax); ax.grid(axis='y', alpha=0.35)
    for bar, val, vol in zip(bars, agg['taux'], agg['count']):
        ax.text(bar.get_x()+bar.get_width()/2, bar.get_height()+0.3,
                f'{val:.1f}%\n(n={vol:,})', ha='center', fontsize=8, color='white', fontweight='bold')

    # B. Cumul × Segment → heatmap
    ax = axes[0,1]
    pv = df_multi.pivot_table(values='resilie', index='segment',
                               columns='cat_cumul', observed=True, aggfunc='mean')*100
    pv = pv.dropna(how='all').dropna(axis=1, how='all')
    if pv.size > 0:
        sns.heatmap(pv, ax=ax, cmap=CMAP_RES, annot=True, fmt='.1f',
                    linewidths=0.5, linecolor=BG,
                    cbar_kws={"label":"Taux résiliation (%)"},
                    annot_kws={"size":9,"color":"white","fontweight":"bold"})
        ax.set_title("Cumul hausse × Segment\n→ Taux résiliation")
        ax.tick_params(axis='x', rotation=35, labelsize=8)
    else:
        ax.text(0.5, 0.5, "Données insuffisantes", ha='center', va='center',
                transform=ax.transAxes, color='white')
        ax.set_title("Cumul hausse × Segment")

    # C. Évolution taux résiliation selon cumul par année
    ax = axes[1,0]
    for annee in sorted(df_multi['annee'].unique()):
        sub = df_multi[df_multi['annee']==annee]
        agg2 = sub.groupby('cat_cumul', observed=True)['resilie'].mean().reset_index()
        agg2.columns = ['cat','taux']; agg2['taux'] *= 100
        ax.plot(agg2['cat'].astype(str), agg2['taux'],
                marker='o', lw=2, label=str(annee), markersize=6)
    ax.set_title("Effet cumul par année\n(contrats multi-termes)")
    ax.set_xlabel("Catégorie de cumul"); ax.set_ylabel("Taux (%)")
    ax.legend(fontsize=9); ax.tick_params(axis='x', rotation=35)
    ax_clean(ax); ax.grid(alpha=0.35)

    # D. Distribution cumul_hausse_hist : résiliés vs actifs
    ax = axes[1,1]
    for val, lbl, c in [(0,'Actif',BLEU),(1,'Résilié',ROUGE)]:
        d = df_multi[(df_multi['resilie']==val) & df_multi['cumul_hausse_hist'].notna()]
        dd = d['cumul_hausse_hist'].clip(-20, 80)
        if len(dd) > 20:
            ax.hist(dd, bins=40, alpha=0.42, color=c, density=True, label=lbl)
            try:
                kde = gaussian_kde(dd, bw_method=0.2)
                xr = np.linspace(dd.min(), dd.max(), 300)
                ax.plot(xr, kde(xr), color=c, lw=2.5)
            except: pass
    ax.set_title("Distribution du cumul de hausses\n(résiliés vs actifs, multi-termes)")
    ax.set_xlabel("Cumul hausses (%)"); ax.set_ylabel("Densité")
    ax.legend(fontsize=9); ax_clean(ax); ax.grid(alpha=0.3)

    plt.tight_layout()
    sauvegarder(fig, "03_effet_cumul.png")

