def metrics_annuelles(bases):
    rows = []
    for an, df in sorted(bases.items()):
        res = df[df["resilie"]==1]
        rows.append({
            "annee"            : an,
            "nb_contrats"      : len(df),
            "nb_resilies"      : int(res.shape[0]),
            "taux"             : df["resilie"].mean()*100,
            "prime_global"     : df["prime_ttc"].mean(),
            "prime_resilies"   : res["prime_ttc"].mean(),
            "delta_prime_moy"  : df["delta_prime_pct"].mean(),
        })
    return pd.DataFrame(rows).set_index("annee")

