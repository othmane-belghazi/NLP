# 10. VISUEL 5 : TABLEAU RANKING FINAL
# ══════════════════════════════════════════════════════════════════════════════
interpretations = {
    "age_conducteur": "U-shape. Jeunes + 80+ = CT élevé",
    "anciennete": "Linéaire ↓. Fidélité = CT stabilisé",
    "majoration": "Linéaire ↑. Top driver systématique",
    "zone_geo": "CT ↑ zones risquées (urbain)",
    "formule": "Tous Risques > Intermédiaire > Tiers",
    "puissance": "Effet log, marginal > 10 CV",
    "usage": "Trajet domicile-travail = CT ↑",
