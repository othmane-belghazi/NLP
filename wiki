# ══════════════════════════════════════════════════════════════════════════════
# 1. BASE CONTRATS — ÂGE CONDUCTEUR (18 → 95 ans)
# ══════════════════════════════════════════════════════════════════════════════
np.random.seed(42)
N = 80_000

# Âge conducteur : distribution réaliste, pic 35-55, queue vers 90+
age_probs = np.array([
    np.exp(-0.5*((a-45)/15)**2) + 0.05*np.exp(-0.5*((a-75)/10)**2)
    for a in range(18, 96)
])
age_probs /= age_probs.sum()
age_cond = np.random.choice(np.arange(18, 96), size=N, p=age_probs)

anciennete = np.clip(np.random.exponential(5, N).astype(int), 0, 25)
majoration = np.clip(np.random.normal(5, 8, N).astype(int), -7, 30)

# Prime AN : croît avec âge (surtout 80+)
prime_an = np.clip(
    300 + 2.0*age_cond + 0.08*(age_cond**1.3) + 4*majoration
    + np.random.normal(0, 40, N), 150, 1200)

# CT implicite : plus dispersé et plus élevé pour 80+
ct_base = 1.15 + np.where(age_cond >= 80,
    0.08 + 0.004*(age_cond - 80) + np.random.normal(0, 0.08, N),  # 80+ : CT élevé + dispersé
    0.001*(age_cond - 50)**2 / 500 + np.random.normal(0, 0.04, N)  # <80 : CT stable
)
ct_base += 0.002 * majoration - 0.002 * anciennete
ct_ind = np.clip(ct_base, 0.85, 1.65)

prime_ptf = prime_an * ct_ind

df = pd.DataFrame({
    "prime_an": np.round(prime_an, 2),
    "prime_ptf": np.round(prime_ptf, 2),
    "ct": np.round(ct_ind, 4),
    "age_conducteur": age_cond,
    "anciennete": anciennete,
    "majoration": majoration,
})

# Tranches d'âge
bins_age = [17, 25, 35, 45, 55, 65, 75, 80, 85, 90, 95]
labels_age = ["18-25", "26-35", "36-45", "46-55", "56-65",
              "66-75", "76-80", "81-85", "86-90", "91-95"]
df["tranche_age"] = pd.cut(df["age_conducteur"], bins=bins_age, labels=labels_age)

ct_global = df["prime_ptf"].sum() / df["prime_an"].sum()
print(f"Base : {len(df):,} contrats | CT global : {ct_global:.4f}")
print(f"Dont 80+ : {(df['age_conducteur']>=80).sum():,} contrats")


# ══════════════════════════════════════════════════════════════════════════════
# 2. TABLEAU RÉCAP PAR QUANTILE D'ÂGE
# ══════════════════════════════════════════════════════════════════════════════
def build_recap_table(df, group_col):
    rows = []
    for name, grp in df.groupby(group_col, observed=True):
        ct_seg = grp["prime_ptf"].sum() / grp["prime_an"].sum()
        ct_vals = grp["ct"]
        q1, med, q3 = ct_vals.quantile([0.25, 0.5, 0.75])
        p10, p90 = ct_vals.quantile([0.10, 0.90])
        iqr = q3 - q1
        skew = ct_vals.skew()
        kurt = ct_vals.kurtosis()
        rows.append({
            "Tranche": name,
            "N contrats": len(grp),
            "% Ptf": len(grp) / len(df) * 100,
            "Σ Prime AN": grp["prime_an"].sum(),
            "CT agrégé": ct_seg,
            "CT moyen": ct_vals.mean(),
            "CT médian": med,
            "Écart-type": ct_vals.std(),
            "CV (%)": ct_vals.std() / ct_vals.mean() * 100,
            "P10": p10, "Q1": q1, "Q3": q3, "P90": p90,
            "IQR": iqr,
            "Skewness": skew,
            "Kurtosis": kurt,
        })
    return pd.DataFrame(rows)

recap = build_recap_table(df, "tranche_age")
print("\n" + recap.to_string(index=False, float_format="%.4f"))


