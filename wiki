# BLOC 1 — SIMULATION DES DONNÉES (remplacer par lecture réelle)
# ══════════════════════════════════════════════════════════════════════════════
def simuler_base(annee, n, seed):
    np.random.seed(seed)
    segments  = ['SR','JC','BB','EC','HR']
    canaux    = ['Agent','Courtier','Direct','Bancassurance']
    produits  = ['Tiers','Tiers+','Tous Risques']
    regions   = ['IDF','PACA','ARA','NAQ','OCC','HDF','BRE','GES']
    energies  = ['Essence','Diesel','Hybride','Electrique']
    classes_v = ['A','B','C','D','E']
    motifs    = ['Vente véhicule','Loi Hamon','Non-paiement','Décès','Autre assureur','Fin contrat','Motif inconnu']

    seg  = np.random.choice(segments,  n, p=[0.33,0.14,0.20,0.20,0.13])
    can  = np.random.choice(canaux,    n, p=[0.35,0.30,0.25,0.10])
    prod = np.random.choice(produits,  n, p=[0.30,0.35,0.35])
    reg  = np.random.choice(regions,   n)
    en   = np.random.choice(energies,  n, p=[0.40,0.35,0.15,0.10])
    cls  = np.random.choice(classes_v, n, p=[0.15,0.25,0.30,0.20,0.10])
    age  = np.random.randint(18, 76, n)
    anc  = np.random.randint(0, 20, n)
    bm   = np.round(np.random.uniform(0.50, 2.30, n), 3)
    sin_nr = np.random.poisson(0.15, n)
    sin_r  = np.random.poisson(0.12, n)

    base_prime = np.where(seg=='JC', 1200,
                 np.where(seg=='HR',  980,
                 np.where(seg=='EC',  860,
                 np.where(seg=='SR',  690, 620))))
    prime_prec = base_prime + np.random.normal(0, 100, n)
    prime_prec = np.clip(prime_prec, 300, 3000)

    hausse_moy = 0.065 if annee >= 2023 else 0.025
    var_rel    = np.random.normal(hausse_moy, 0.08, n)
    prime_comm = prime_prec * (1 + var_rel)
    prime_comm = np.clip(prime_comm, 300, 3000)

    # Probabilité de résiliation
    p = 0.09 + np.where(seg=='JC', 0.09, np.where(seg=='BB', 0.02, 0.0))
    p += np.clip(var_rel * 4, 0, 0.25)
    p += np.where(sin_r > 0, 0.03, 0.0)
    p += np.where(prime_comm > 1200, 0.02, 0.0)
    p += np.where(prime_comm > 1600, 0.03, 0.0)
    p += np.where(bm > 1.5, 0.02, 0.0)
    p += np.where(anc < 2, 0.04, np.where(anc > 10, -0.03, 0.0))
    p = np.clip(p, 0.02, 0.75)
    resilie = np.random.binomial(1, p, n).astype(bool)

    date_terme = pd.Timestamp(f'{annee}-01-01') + pd.to_timedelta(
        np.random.randint(0, 365, n), unit='D')
    date_resil = np.where(
        resilie,
        (date_terme + pd.to_timedelta(np.random.randint(0, 30, n), unit='D')).astype(str),
        pd.NaT)

    motif_arr = np.where(
        resilie,
        np.random.choice(motifs, n, p=[0.18,0.22,0.10,0.05,0.28,0.10,0.07]),
        None)

    return pd.DataFrame({
        'num_contrat':      [f'C{annee}{i:07d}' for i in range(n)],
        'annee':            annee,
        'bonus_malus':      bm,
        'age':              age,
        'classe_vehicule':  cls,
        'energie_vehicule': en,
        'nb_sin_nr_12m':    sin_nr,
        'nb_sin_r_12m':     sin_r,
        'anciennete':       anc,
        'prime_comm':       np.round(prime_comm, 2),
        'prime_comm_prec':  np.round(prime_prec, 2),
        'date_resil':       date_resil,
        'date_terme':       date_terme,
        'motif_resil':      motif_arr,
        'segment':          seg,
        'canal':            can,
        'produit':          prod,
        'region':           reg,
    })

