# BLOC 2 — CHARGEMENT & EMPILEMENT
# ══════════════════════════════════════════════════════════════════════════════
def charger_bases(chemins: dict) -> pd.DataFrame:
    """
    Production : passer un dict {annee: chemin_fichier}
    Ex : {2022:'data/base2022.csv', 2023:'data/base2023.csv', ...}
    Remplacer pd.read_csv par pd.read_excel ou autre selon format.
    """
    dfs = []
    for annee, chemin in chemins.items():
        df = pd.read_csv(chemin, sep=';', encoding='utf-8')
        df['annee'] = int(annee)
        dfs.append(df)
    return pd.concat(dfs, ignore_index=True)

def charger_donnees_simulees() -> pd.DataFrame:
    """ Remplacer cette fonction par charger_bases() en production """
    configs = [(2022, 8500, 10), (2023, 9200, 20), (2024, 9800, 30), (2025, 8000, 40)]
    return pd.concat([simuler_base(a, n, s) for a, n, s in configs], ignore_index=True)

