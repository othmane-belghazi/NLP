"""
════════════════════════════════════════════════════════════════════════════════
PIPELINE CATBOOST — FEATURE IMPORTANCE DU CT
════════════════════════════════════════════════════════════════════════════════
Objectif : identifier et visualiser les variables qui influencent le CT
Modèle   : CatBoostRegressor (gère nativement les catégorielles)
Sortie   : 5 visuels PNG + tableau console

Prérequis : pip install catboost shap matplotlib pandas scikit-learn
════════════════════════════════════════════════════════════════════════════════
"""

import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import matplotlib.ticker as mticker
from matplotlib.lines import Line2D
from matplotlib.patches import Patch
import warnings
warnings.filterwarnings("ignore")

# ══════════════════════════════════════════════════════════════════════════════
# 0. PALETTE & CONFIG
# ══════════════════════════════════════════════════════════════════════════════
NAVY     = "#0B2447"
DEEP     = "#153B6B"
MID_BLUE = "#1B6DA3"
SKY      = "#6EB4D9"
PALE     = "#A8D4EE"
BG       = "#F7F5F0"
TEXT     = "#1C2D3F"
SUBTLE   = "#8FA3B8"
WARN     = "#D4760A"
RED      = "#C0392B"
GREEN    = "#2E7D5B"

OUTPUT_DIR = "."  # ← adapter si besoin


# ══════════════════════════════════════════════════════════════════════════════
# 1. SIMULATION DE LA BASE CONTRATS
# ══════════════════════════════════════════════════════════════════════════════
# ⚠️  REMPLACER CE BLOC PAR TA VRAIE BASE
#     df = spark.sql("SELECT * FROM ta_table").toPandas()
#     ou df = pd.read_csv("ta_base.csv")
#     puis adapter les noms de colonnes

np.random.seed(42)
N = 60_000

age_cond = np.random.choice(np.arange(18, 96), size=N,
    p=(lambda x: x/x.sum())(np.array([
        np.exp(-0.5*((a-45)/15)**2) + 0.05*np.exp(-0.5*((a-75)/10)**2)
        for a in range(18, 96)])))

anciennete = np.clip(np.random.exponential(5, N).astype(int), 0, 25)
majoration = np.clip(np.random.normal(5, 8, N).astype(int), -7, 30)
canal = np.random.choice(["Agent", "Courtier", "Direct"], N, p=[0.45, 0.35, 0.20])
zone_geo = np.random.choice([1, 2, 3, 4, 5, 6], N, p=[0.10, 0.20, 0.25, 0.22, 0.15, 0.08])
formule = np.random.choice(["Tiers", "Intermédiaire", "Tous Risques"], N, p=[0.30, 0.35, 0.35])
puissance = np.clip(np.random.lognormal(1.6, 0.4, N).astype(int), 3, 25)
usage = np.random.choice(["Loisir", "Trajet"], N, p=[0.65, 0.35])
freq_sinistre = np.clip(np.random.exponential(0.15, N), 0, 1.5)
nb_sinistres_3ans = np.random.poisson(0.4, N)
nb_conducteurs = np.random.choice([1, 2, 3], N, p=[0.60, 0.30, 0.10])

# Prime AN (NON incluse dans le modèle — juste pour calculer CT)
prime_an = np.clip(
    200 + 1.8*age_cond + 15*puissance + 20*zone_geo + 5*majoration
    + 30*(formule == "Tous Risques").astype(int)
    + 40*freq_sinistre + np.random.normal(0, 35, N), 120, 1500)

# CT cible
canal_effect = np.where(canal == "Direct", -0.02, np.where(canal == "Courtier", 0.015, 0))
formule_effect = np.where(formule == "Tous Risques", 0.01, np.where(formule == "Tiers", -0.005, 0))
usage_effect = np.where(usage == "Trajet", 0.012, 0)

ct = np.clip(
    1.12
    - 0.004 * anciennete
    + 0.0015 * np.abs(age_cond - 45)
    + np.where(age_cond >= 80, 0.06 + 0.003*(age_cond-80), 0)
    + 0.0025 * majoration
    + canal_effect
    + 0.008 * (zone_geo - 3)
    + formule_effect
    + usage_effect
    + 0.04 * freq_sinistre
    + 0.008 * nb_sinistres_3ans
    + 0.005 * (nb_conducteurs - 1)
    + np.random.normal(0, 0.035, N),
    0.85, 1.60)

df = pd.DataFrame({
    "age_conducteur": age_cond,
    "anciennete": anciennete,
    "majoration": majoration,
    "canal": canal,
    "zone_geo": zone_geo,
    "formule": formule,
    "puissance": puissance,
    "usage": usage,
    "freq_sinistre": np.round(freq_sinistre, 4),
    "nb_sinistres_3ans": nb_sinistres_3ans,
    "nb_conducteurs": nb_conducteurs,
    "ct": np.round(ct, 4),
})

print(f"{'='*70}")
print(f"  BASE : {N:,} contrats | CT moyen : {df['ct'].mean():.4f}")
print(f"{'='*70}")
print(df.head(8).to_string(index=False))


# ══════════════════════════════════════════════════════════════════════════════
# 2. PRÉPARATION FEATURES
# ══════════════════════════════════════════════════════════════════════════════

# ── Variables catégorielles (CatBoost les gère nativement) ────────────────────
CAT_FEATURES = ["canal", "formule", "usage"]

# ── Variables numériques ──────────────────────────────────────────────────────
NUM_FEATURES = [
    "age_conducteur", "anciennete", "majoration", "zone_geo",
    "puissance", "freq_sinistre", "nb_sinistres_3ans", "nb_conducteurs",
]

# ── Variables dérivées (interactions) ─────────────────────────────────────────
df["age_x_anciennete"] = df["age_conducteur"] * df["anciennete"]
df["maj_x_anciennete"] = df["majoration"] * df["anciennete"]
df["is_80plus"] = (df["age_conducteur"] >= 80).astype(int)

INTERACTION_FEATURES = ["age_x_anciennete", "maj_x_anciennete", "is_80plus"]

# ── Liste complète ────────────────────────────────────────────────────────────
ALL_FEATURES = NUM_FEATURES + CAT_FEATURES + INTERACTION_FEATURES
TARGET = "ct"

# ⛔ EXCLUSIONS (pas de prime AN / prime Ptf → leakage)
print(f"\n⛔ Variables exclues : prime_an, prime_ptf (composantes du CT)")
print(f"✅ Features retenues : {len(ALL_FEATURES)}")
print(f"   Numériques     : {NUM_FEATURES}")
print(f"   Catégorielles  : {CAT_FEATURES}")
print(f"   Interactions   : {INTERACTION_FEATURES}")

LABELS_FR = {
    "age_conducteur": "Âge conducteur", "anciennete": "Ancienneté",
    "majoration": "Majoration / Malus", "zone_geo": "Zone géographique",
    "puissance": "Puissance (CV)", "freq_sinistre": "Fréq. sinistres",
    "nb_sinistres_3ans": "Nb sin. 3 ans", "nb_conducteurs": "Nb conducteurs",
    "canal": "Canal distribution", "formule": "Formule garantie",
    "usage": "Usage véhicule", "age_x_anciennete": "Âge × Ancienneté",
    "maj_x_anciennete": "Majo × Ancienneté", "is_80plus": "Flag 80+",
}

GROUPE = {f: "Tarifaire" for f in NUM_FEATURES[:5]}
GROUPE.update({f: "Comportemental" for f in NUM_FEATURES[5:] + CAT_FEATURES})
GROUPE.update({"usage": "Tarifaire"})
GROUPE.update({f: "Interaction" for f in INTERACTION_FEATURES})


# ══════════════════════════════════════════════════════════════════════════════
# 3. TRAIN / TEST SPLIT
# ══════════════════════════════════════════════════════════════════════════════
from sklearn.model_selection import train_test_split

X = df[ALL_FEATURES].copy()
y = df[TARGET]

# CatBoost veut les cat features en string
for col in CAT_FEATURES:
    X[col] = X[col].astype(str)

X_train, X_test, y_train, y_test = train_test_split(
    X, y, test_size=0.25, random_state=42)

cat_indices = [ALL_FEATURES.index(c) for c in CAT_FEATURES]

print(f"\nTrain : {len(X_train):,} | Test : {len(X_test):,}")


# ══════════════════════════════════════════════════════════════════════════════
# 4. CATBOOST — ENTRAÎNEMENT
# ══════════════════════════════════════════════════════════════════════════════
from catboost import CatBoostRegressor, Pool

train_pool = Pool(X_train, y_train, cat_features=cat_indices)
test_pool = Pool(X_test, y_test, cat_features=cat_indices)

model = CatBoostRegressor(
    iterations=800,
    learning_rate=0.05,
    depth=6,
    l2_leaf_reg=3,
    min_data_in_leaf=50,
    subsample=0.8,
    random_seed=42,
    verbose=100,
    eval_metric="MAE",
    early_stopping_rounds=50,
)

model.fit(train_pool, eval_set=test_pool, use_best_model=True)

from sklearn.metrics import mean_absolute_error, r2_score, mean_squared_error

y_pred = model.predict(X_test)
mae = mean_absolute_error(y_test, y_pred)
rmse = np.sqrt(mean_squared_error(y_test, y_pred))
r2 = r2_score(y_test, y_pred)

print(f"\n{'='*50}")
print(f"  PERFORMANCE CATBOOST")
print(f"  R²   = {r2:.4f}")
print(f"  MAE  = {mae:.5f}")
print(f"  RMSE = {rmse:.5f}")
print(f"{'='*50}")


# ══════════════════════════════════════════════════════════════════════════════
# 5. FEATURE IMPORTANCE — 3 MÉTHODES CATBOOST
# ══════════════════════════════════════════════════════════════════════════════

# A. Importance native CatBoost (PredictionValuesChange)
imp_native = model.get_feature_importance(train_pool, type="PredictionValuesChange")

# B. Importance par LossFunctionChange (plus fiable)
imp_loss = model.get_feature_importance(train_pool, type="LossFunctionChange")

# C. SHAP values
shap_values = model.get_feature_importance(train_pool, type="ShapValues")
# CatBoost retourne shap_values avec une colonne bias en dernier
shap_vals = shap_values[:, :-1]
shap_imp = np.abs(shap_vals).mean(axis=0)

# D. Permutation importance (sklearn)
from sklearn.inspection import permutation_importance
perm = permutation_importance(model, X_test, y_test,
                               n_repeats=15, random_state=42, n_jobs=-1)

# ── Consolidation ─────────────────────────────────────────────────────────────
imp = pd.DataFrame({
    "feature": ALL_FEATURES,
    "native": imp_native,
    "loss_change": imp_loss,
    "shap": shap_imp,
    "permutation": perm.importances_mean,
    "perm_std": perm.importances_std,
})

for col in ["native", "loss_change", "shap", "permutation"]:
    imp[f"{col}_pct"] = imp[col] / imp[col].sum() * 100

imp["rang_moyen"] = (
    imp["native_pct"].rank(ascending=False) +
    imp["loss_change_pct"].rank(ascending=False) +
    imp["shap_pct"].rank(ascending=False) +
    imp["permutation_pct"].rank(ascending=False)
) / 4

imp = imp.sort_values("rang_moyen")
imp["label_fr"] = imp["feature"].map(LABELS_FR)
imp["groupe"] = imp["feature"].map(GROUPE)

print("\n── RANKING CONSENSUS (4 méthodes) ──")
print(imp[["feature", "groupe", "native_pct", "loss_change_pct",
           "shap_pct", "permutation_pct", "rang_moyen"]]
      .to_string(index=False, float_format="%.1f"))


# ══════════════════════════════════════════════════════════════════════════════
# 6. VISUEL 1 : COMPARAISON 4 MÉTHODES (barres horizontales)
# ══════════════════════════════════════════════════════════════════════════════
fig, axes = plt.subplots(2, 2, figsize=(20, 13), facecolor=BG,
                          gridspec_kw={"hspace": 0.35, "wspace": 0.30})

group_colors = {"Tarifaire": MID_BLUE, "Comportemental": WARN, "Interaction": SKY}

configs = [
    ("native_pct", "CatBoost — PredictionValuesChange", NAVY),
    ("loss_change_pct", "CatBoost — LossFunctionChange", DEEP),
    ("shap_pct", "CatBoost — SHAP (|mean|)", MID_BLUE),
    ("permutation_pct", "Permutation Importance (sklearn)", WARN),
]

for ax, (col, title, default_color) in zip(axes.flat, configs):
    ax.set_facecolor(BG)
    df_plot = imp.sort_values(col, ascending=True)
    bar_colors = [group_colors.get(g, default_color) for g in df_plot["groupe"]]

    ax.barh(range(len(df_plot)), df_plot[col],
            color=bar_colors, edgecolor="white", linewidth=0.5, height=0.65)
    for i, (val, lbl) in enumerate(zip(df_plot[col], df_plot["label_fr"])):
        ax.text(val + 0.3, i, f"{val:.1f}%", va="center", fontsize=8.5,
                color=TEXT, fontweight="bold")

    ax.set_yticks(range(len(df_plot)))
    ax.set_yticklabels(df_plot["label_fr"], fontsize=9.5, color=TEXT)
    ax.set_xlabel("Importance (%)", fontsize=10, color=TEXT)
    ax.set_title(title, fontsize=11, fontweight="bold", color=NAVY, pad=10)
    ax.tick_params(axis="x", labelsize=9, colors=TEXT)
    ax.grid(False)
    for sp in ax.spines.values():
        sp.set_visible(False)

leg = [Patch(color=MID_BLUE, label="Tarifaire"),
       Patch(color=WARN, label="Comportemental"),
       Patch(color=SKY, label="Interaction")]
axes[0, 0].legend(handles=leg, fontsize=8, loc="lower right",
                   frameon=True, fancybox=True, edgecolor="#D6E2ED", facecolor="white")

fig.suptitle(
    f"Feature Importance CatBoost — 4 méthodes croisées\n"
    f"R² = {r2:.4f}  |  MAE = {mae:.5f}  |  RMSE = {rmse:.5f}",
    fontsize=15, fontweight="bold", color=NAVY, y=0.99)
fig.text(0.5, 0.005,
    "Native = PredictionValuesChange · LossChange = impact sur la loss · "
    "SHAP = contribution marginale · Permutation = dégradation MAE",
    ha="center", fontsize=9, color=SUBTLE, style="italic")

plt.savefig(f"{OUTPUT_DIR}/catboost_importance_4methods.png", dpi=200, bbox_inches="tight")
plt.close()
print("\nOK  catboost_importance_4methods.png")


# ══════════════════════════════════════════════════════════════════════════════
# 7. VISUEL 2 : SHAP BEESWARM (summary plot)
# ══════════════════════════════════════════════════════════════════════════════
fig_shap, ax_shap = plt.subplots(figsize=(14, 9), facecolor=BG)
ax_shap.set_facecolor(BG)

# Ordre par importance SHAP
order = np.argsort(np.abs(shap_vals).mean(axis=0))[::-1]

# Sous-échantillon pour le plot
n_sample = min(3000, len(shap_vals))
rng = np.random.default_rng(42)
sample_idx = rng.choice(len(shap_vals), n_sample, replace=False)

for rank, feat_idx in enumerate(order[::-1]):  # bottom to top
    feat_name = ALL_FEATURES[feat_idx]
    vals = shap_vals[sample_idx, feat_idx]

    # Valeurs de la feature (pour la couleur)
    feat_vals = X_train.iloc[sample_idx, feat_idx]
    if feat_name in CAT_FEATURES:
        # Encoder en numérique pour la couleur
        feat_vals = pd.Categorical(feat_vals).codes.astype(float)
    else:
        feat_vals = feat_vals.values.astype(float)

    fmin, fmax = np.nanpercentile(feat_vals, [2, 98])
    if fmax > fmin:
        normed = np.clip((feat_vals - fmin) / (fmax - fmin), 0, 1)
    else:
        normed = np.full_like(feat_vals, 0.5)

    jitter = np.random.normal(0, 0.15, len(vals))
    ax_shap.scatter(vals, rank + jitter, c=normed, cmap="RdYlBu_r",
                    s=6, alpha=0.45, edgecolors="none", rasterized=True)

ax_shap.set_yticks(range(len(order)))
ax_shap.set_yticklabels([LABELS_FR.get(ALL_FEATURES[i], ALL_FEATURES[i])
                          for i in order[::-1]], fontsize=10, color=TEXT)
ax_shap.axvline(0, color=SUBTLE, linewidth=1, alpha=0.5)
ax_shap.set_xlabel("SHAP value (impact sur le CT prédit)", fontsize=11, color=TEXT)
ax_shap.set_title("SHAP Summary — Direction & magnitude de chaque variable",
                   fontsize=14, fontweight="bold", color=NAVY, pad=12)
ax_shap.tick_params(axis="x", labelsize=9, colors=TEXT)

sm = plt.cm.ScalarMappable(cmap="RdYlBu_r", norm=plt.Normalize(0, 1))
sm.set_array([])
cbar = fig_shap.colorbar(sm, ax=ax_shap, fraction=0.02, pad=0.04)
cbar.set_ticks([0, 1])
cbar.set_ticklabels(["Valeur basse", "Valeur haute"])
cbar.ax.tick_params(labelsize=9, colors=TEXT)

ax_shap.grid(False)
for sp in ax_shap.spines.values():
    sp.set_visible(False)

fig_shap.text(0.5, 0.005,
    "Chaque point = 1 contrat · X = impact SHAP sur CT · "
    "Rouge = valeur haute de la variable · Bleu = valeur basse",
    ha="center", fontsize=9, color=SUBTLE, style="italic")

plt.savefig(f"{OUTPUT_DIR}/catboost_shap_summary.png", dpi=200, bbox_inches="tight")
plt.close()
print("OK  catboost_shap_summary.png")


# ══════════════════════════════════════════════════════════════════════════════
# 8. VISUEL 3 : SHAP DEPENDENCE PLOTS (top 6)
# ══════════════════════════════════════════════════════════════════════════════
top6_idx = order[:6]

fig_dep, axes_dep = plt.subplots(2, 3, figsize=(20, 11), facecolor=BG,
                                  gridspec_kw={"hspace": 0.35, "wspace": 0.25})

for ax, feat_idx in zip(axes_dep.flat, top6_idx):
    ax.set_facecolor(BG)
    feat_name = ALL_FEATURES[feat_idx]

    feat_vals = X_train.iloc[sample_idx, feat_idx]
    sv = shap_vals[sample_idx, feat_idx]

    if feat_name in CAT_FEATURES:
        # Boxplot par catégorie
        cats = feat_vals.unique()
        data_by_cat = [sv[feat_vals == c] for c in sorted(cats)]
        bp = ax.boxplot(data_by_cat, patch_artist=True, widths=0.5,
                        showfliers=False)
        colors_bp = plt.cm.Blues(np.linspace(0.3, 0.7, len(cats)))
        for patch, color in zip(bp["boxes"], colors_bp):
            patch.set_facecolor(color)
            patch.set_edgecolor(NAVY)
        for m in bp["medians"]:
            m.set_color(WARN)
            m.set_linewidth(2)
        ax.set_xticklabels(sorted(cats), fontsize=9, color=TEXT)
    else:
        feat_vals_num = feat_vals.values.astype(float)
        sc = ax.scatter(feat_vals_num, sv, c=feat_vals_num, cmap="RdYlBu_r",
                        s=8, alpha=0.35, edgecolors="none", rasterized=True)
        # Trend
        sort_i = np.argsort(feat_vals_num)
        window = max(len(feat_vals_num) // 30, 10)
        tx = pd.Series(feat_vals_num[sort_i]).rolling(window, center=True).mean()
        ty = pd.Series(sv[sort_i]).rolling(window, center=True).mean()
        ax.plot(tx, ty, color=RED, linewidth=2.5, zorder=5)

    ax.axhline(0, color=SUBTLE, linewidth=1, alpha=0.5)

    delta = sv.max() - sv.min()
    ax.text(0.02, 0.95, f"Δ SHAP = {delta:.4f}", transform=ax.transAxes,
            fontsize=9, color=DEEP, fontweight="bold", va="top",
            bbox=dict(boxstyle="round,pad=0.3", facecolor="white",
                      edgecolor="#D6E2ED", alpha=0.9))

    ax.set_xlabel(LABELS_FR.get(feat_name, feat_name), fontsize=10, color=TEXT)
    ax.set_ylabel("SHAP value", fontsize=10, color=TEXT)
    ax.set_title(LABELS_FR.get(feat_name, feat_name),
                 fontsize=11, fontweight="bold", color=NAVY, pad=8)
    ax.tick_params(labelsize=8, colors=TEXT)
    ax.grid(False)
    for sp in ax.spines.values():
        sp.set_visible(False)

fig_dep.suptitle("SHAP Dependence Plots — Effet de chaque variable sur le CT (CatBoost)",
                 fontsize=16, fontweight="bold", color=NAVY, y=0.99)
fig_dep.text(0.5, 0.005,
    "Ligne rouge = tendance · Positif = augmente CT · Négatif = diminue CT · "
    "Variables catégorielles = boxplot par modalité",
    ha="center", fontsize=9, color=SUBTLE, style="italic")

plt.savefig(f"{OUTPUT_DIR}/catboost_shap_dependence.png", dpi=200, bbox_inches="tight")
plt.close()
print("OK  catboost_shap_dependence.png")


# ══════════════════════════════════════════════════════════════════════════════
# 9. VISUEL 4 : SHAP INTERACTION (top 2 variables)
# ══════════════════════════════════════════════════════════════════════════════
top2 = [ALL_FEATURES[i] for i in order[:2]]

fig_int, ax_int = plt.subplots(figsize=(12, 8), facecolor=BG)
ax_int.set_facecolor(BG)

feat1, feat2 = top2[0], top2[1]
f1_vals = X_train.iloc[sample_idx][feat1].values.astype(float)
f2_vals = X_train.iloc[sample_idx][feat2].values.astype(float)
shap1 = shap_vals[sample_idx, ALL_FEATURES.index(feat1)]

sc = ax_int.scatter(f1_vals, shap1, c=f2_vals, cmap="RdYlBu_r",
                    s=12, alpha=0.5, edgecolors="none", rasterized=True)

cbar = fig_int.colorbar(sc, ax=ax_int, fraction=0.03, pad=0.04)
cbar.set_label(LABELS_FR.get(feat2, feat2), fontsize=10, color=TEXT)
cbar.ax.tick_params(labelsize=9, colors=TEXT)

ax_int.axhline(0, color=SUBTLE, linewidth=1, alpha=0.5)
ax_int.set_xlabel(LABELS_FR.get(feat1, feat1), fontsize=12, color=TEXT)
ax_int.set_ylabel(f"SHAP value de {LABELS_FR.get(feat1, feat1)}", fontsize=12, color=TEXT)
ax_int.set_title(f"Interaction SHAP : {LABELS_FR[feat1]} coloré par {LABELS_FR[feat2]}",
                 fontsize=14, fontweight="bold", color=NAVY, pad=12)
ax_int.tick_params(labelsize=9, colors=TEXT)
ax_int.grid(False)
for sp in ax_int.spines.values():
    sp.set_visible(False)

plt.savefig(f"{OUTPUT_DIR}/catboost_shap_interaction.png", dpi=200, bbox_inches="tight")
plt.close()
print("OK  catboost_shap_interaction.png")


