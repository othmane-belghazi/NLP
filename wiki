df["juste_au_dessus_seuil"] = ((df["prime_proposee"] % 100 <= 15) & (df["prime_proposee"] % 100 > 0)).astype(int)

# --- 3D. ÉCART PREMIÈRE PRIME / DERNIÈRE ---
df["ecart_premiere_derniere_euros"] = df["prime_proposee"] - df["premiere_prime_connue"]
df["ecart_premiere_derniere_pct"] = np.where(
    df["premiere_prime_connue"] > 0,
    (df["prime_proposee"] - df["premiere_prime_connue"]) / df["premiere_prime_connue"] * 100,
    0
)
df["ratio_prime_actuelle_premiere"] = np.where(
    df["premiere_prime_connue"] > 0,
    df["prime_proposee"] / df["premiere_prime_connue"],
    1
)

# --- 3E. VARIABLES ENRICHIES ---
df["tranche_prime"] = pd.cut(df["prime_proposee"],
    bins=[0, 300, 500, 700, 1000, 9999],
    labels=["< 300€", "300-500€", "500-700€", "700-1000€", ">= 1000€"])

df["anciennete_portefeuille"] = (
    df["prime_proposee_2024"].notna().astype(int) +
