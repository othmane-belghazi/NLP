        'cumul_hausse_hist','cat_cumul',
        'mois_terme','trim_terme',
        'score_pression','cat_risque',
        'multi_annees','nb_termes_obs',
        'date_terme','date_resil','motif_resil','motif_simplifie',
        'resilie',
    ]
    cols_ok = [c for c in cols_export if c in df.columns]
