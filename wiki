# ─── G10  Boxplots comparatifs ────────────────────────────────────────────────
def g10_boxplots(df):
    fig, axes = plt.subplots(2, 3, figsize=(20, 12))
    fig.suptitle("Comparaison Statistique — Résiliés vs Non Résiliés")

    vars_box = [
        ('prime_comm',      "Prime commerciale (€)"),
        ('var_rel_prime',   "Variation prime (%)"),
        ('bonus_malus',     "Bonus-Malus"),
        ('anciennete',      "Ancienneté (ans)"),
        ('nb_sin_total',    "Nb sinistres total"),
        ('score_pression',  "Score pression tarifaire"),
    ]

    for ax, (var, label) in zip(axes.flatten(), vars_box):
        d0 = df[df['resilie']==0][var].dropna()
        d1 = df[df['resilie']==1][var].dropna()
        d0c = d0.clip(d0.quantile(0.01), d0.quantile(0.99))
        d1c = d1.clip(d1.quantile(0.01), d1.quantile(0.99))

        bp = ax.boxplot([d0c, d1c], patch_artist=True, notch=True,
                        widths=0.42,
                        medianprops=dict(color='white', lw=2.5),
                        flierprops=dict(marker='.', color=TXT2, alpha=0.2, ms=2))
        bp['boxes'][0].set_facecolor(BLEU);  bp['boxes'][0].set_alpha(0.75)
        bp['boxes'][1].set_facecolor(ROUGE); bp['boxes'][1].set_alpha(0.75)
        for w in bp['whiskers']: w.set_color(TXT2)
        for c in bp['caps']:     c.set_color(TXT2)

        ax.set_xticks([1, 2])
        ax.set_xticklabels(['Actif', 'Résilié'], fontsize=11)
        ax.set_title(label); ax_clean(ax); ax.grid(axis='y', alpha=0.35)

        m0, m1 = d0c.median(), d1c.median()
        diff = (m1 - m0) / abs(m0) * 100 if m0 != 0 else 0
        col = ROUGE if diff > 0 else VERT
        ax.text(0.97, 0.97, f'{"+" if diff>0 else ""}{diff:.1f}%',
                transform=ax.transAxes, ha='right', va='top',
                fontsize=11, fontweight='bold', color=col)
        ax.text(1, m0, f'{m0:.2f}', ha='left',  fontsize=8, color=BLEU,  fontweight='bold')
        ax.text(2, m1, f'{m1:.2f}', ha='right', fontsize=8, color=ROUGE, fontweight='bold')

    lp = [mpatches.Patch(color=BLEU, alpha=0.75, label='Actif'),
          mpatches.Patch(color=ROUGE, alpha=0.75, label='Résilié')]
    fig.legend(handles=lp, loc='upper right', fontsize=11, framealpha=0.5)

    plt.tight_layout()
    sauvegarder(fig, "10_boxplots_comparatifs.png")

