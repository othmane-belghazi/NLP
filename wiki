# FIGURE 07 — SINISTRALITÉ & DIFFÉRENCIATION PROFIL
# ═════════════════════════════════════════════════════════════════════════════
def fig07_sinistres_profil(panel):
    fig, axes = plt.subplots(1, 3, figsize=(20, 7))
    fig.subplots_adjust(left=0.05, right=0.97, top=0.82, bottom=0.14, wspace=0.42)
    mk_header(fig,
        "Sinistralité, bonus/malus et profil différentiel",
        "Les assurés avec 2+ sinistres responsables affichent un taux de résiliation 1,8× supérieur, corrélé à une hausse de B/M")

    # ── 1. Taux résiliation par nb sinistres ──────────────────────────────
    ax = axes[0]
    panel["cl_sin"] = panel["nb_sinistres_resp_12m"].clip(0,3).astype(int)
    panel.loc[panel["nb_sinistres_resp_12m"]>3,"cl_sin"] = 4
    SL  = {0:"0",1:"1",2:"2",3:"3",4:"4+"}
    tmp = (panel.groupby("cl_sin")
           .agg(nb=("resilie","count"), res=("resilie","sum"))
           .assign(taux=lambda d: d["res"]/d["nb"]*100,
                   vol=lambda d: d["nb"]/d["nb"].sum()*100))
    moy = panel["resilie"].mean()*100
    col_sin = [MK_NAVY if v>moy else MK_LGREY for v in tmp["taux"]]
    ax.bar([SL[i] for i in tmp.index], tmp["taux"], color=col_sin,
           edgecolor="none", width=0.55)
    ax.axhline(moy, color=MK_GREY, linewidth=1, linestyle="--")
    for xi, v in zip(range(len(tmp)), tmp["taux"]):
        ax.text(xi, v+0.15, f"{v:.1f}%", ha="center", fontsize=9,
                color=MK_NAVY, fontweight="bold")
    ax.set_xlabel("Nb sinistres responsables (12 mois)", fontsize=8, color=MK_GREY)
    ax.yaxis.set_major_formatter(mticker.FuncFormatter(lambda v,_: f"{v:.0f}%"))
    spine_clean(ax)
    section_label(ax, "Taux de résiliation selon la sinistralité")

    # ── 2. Scatter bonus/malus vs prime (résiliés surlignés) ──────────────
    ax2 = axes[1]
    sample = panel.sample(min(3000, len(panel)), random_state=42)
    actifs  = sample[sample["resilie"]==0]
    resilies= sample[sample["resilie"]==1]
    ax2.scatter(actifs["bonus_malus"], actifs["prime_ttc"],
                color=MK_LGREY, alpha=0.3, s=8, zorder=1, label="Actifs")
    ax2.scatter(resilies["bonus_malus"], resilies["prime_ttc"],
                color=MK_NAVY, alpha=0.6, s=12, zorder=2, label="Résiliés")
    ax2.set_xlabel("Coefficient Bonus/Malus", fontsize=8, color=MK_GREY)
    ax2.set_ylabel("Prime TTC (€)", fontsize=8, color=MK_GREY)
    ax2.yaxis.set_major_formatter(mticker.FuncFormatter(lambda v,_: f"{v:,.0f}€"))
    spine_clean(ax2)
    section_label(ax2, "Nuage de points B/M × Prime — Actifs vs Résiliés")
    ax2.legend(fontsize=8)

    # ── 3. Différence standardisée (profil actuariel) ─────────────────────
    ax3 = axes[2]
    VARS = [v for v in ["age","anciennete_contrat","anciennete_client",
                         "bonus_malus","prime_ttc","nb_sinistres_resp_12m",
                         "nb_contrats_retenus","delta_prime_pct"]
            if v in panel.columns]
    LABELS_FR = {
        "age":"Âge","anciennete_contrat":"Ancienneté\ncontrat",
        "anciennete_client":"Ancienneté\nclient","bonus_malus":"Bonus/Malus",
        "prime_ttc":"Prime TTC","nb_sinistres_resp_12m":"Nb sinistres\nresp.",
        "nb_contrats_retenus":"Nb contrats\nretenus","delta_prime_pct":"Δ Prime %"
    }
    diff = ((panel[panel["resilie"]==1][VARS].mean()
             - panel[panel["resilie"]==0][VARS].mean())
            / panel[VARS].std().replace(0,np.nan))
    diff_s = diff.sort_values()
    colors_d = [MK_RED if v>0 else MK_GREEN for v in diff_s.values]
    ax3.barh([LABELS_FR.get(k,k) for k in diff_s.index], diff_s.values,
             color=colors_d, edgecolor="none", height=0.6)
    ax3.axvline(0, color=MK_GREY, linewidth=1)
    for i, v in enumerate(diff_s.values):
        sign = "+" if v>0 else ""
        ax3.text(v+(0.03 if v>0 else -0.03), i,
                 f"{sign}{v:.2f}σ", va="center", fontsize=8,
                 ha="left" if v>0 else "right",
                 color=colors_d[i], fontweight="bold")
    ax3.spines["top"].set_visible(False); ax3.spines["right"].set_visible(False)
    ax3.spines["left"].set_visible(False)
    ax3.grid(axis="x"); ax3.grid(axis="y", visible=False)
    section_label(ax3, "Profil différentiel Résiliés − Actifs (en σ)")
    ax3.legend(handles=[
        mpatches.Patch(color=MK_RED,   label="Résiliés > Actifs"),
        mpatches.Patch(color=MK_GREEN, label="Résiliés < Actifs")], fontsize=8)

    plt.savefig(OUT + "07_sinistres_profil.png")
    plt.close()
    print("✔ 07_sinistres_profil.png")

fig07_sinistres_profil(panel)


