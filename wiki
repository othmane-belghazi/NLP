# FIGURE 03 — MOTIFS & SAISONNALITÉ
# ═════════════════════════════════════════════════════════════════════════════
def fig03_motifs_saisonnalite(panel, bases):
    fig, axes = plt.subplots(1, 3, figsize=(20, 7),
                              gridspec_kw={"width_ratios":[1,1.3,1.1]})
    fig.subplots_adjust(left=0.05, right=0.97, top=0.82, bottom=0.15, wspace=0.40)
    mk_header(fig,
        "Motifs et saisonnalité des résiliations",
        "L'échéance principale concentre 30 % des départs ; un pic structurel est observé en décembre–janvier sur toutes les années")

    # ── 1. Barres horizontales motifs (classement) ────────────────────────
    ax = axes[0]
    df_r = panel[panel["resilie"]==1]
    motif = df_r["motif_resiliation"].value_counts(normalize=True)*100
    motif_s = motif.sort_values()
    colors_m = [MK_NAVY if i==len(motif_s)-1 else
                (MK_BLUE if i==len(motif_s)-2 else MK_LGREY)
                for i in range(len(motif_s))]
    bars = ax.barh(motif_s.index, motif_s.values,
                   color=colors_m, edgecolor="none", height=0.6)
    for i, (v, name) in enumerate(zip(motif_s.values, motif_s.index)):
        ax.text(v+0.3, i, f"{v:.1f}%", va="center", fontsize=8,
                color=MK_NAVY if colors_m[i]==MK_NAVY else MK_GREY,
                fontweight="bold")
    ax.set_xlim(0, motif_s.max()*1.4)
    ax.xaxis.set_major_formatter(mticker.FuncFormatter(lambda v,_: f"{v:.0f}%"))
    ax.spines["top"].set_visible(False)
    ax.spines["right"].set_visible(False)
    ax.spines["left"].set_visible(False)
    ax.spines["bottom"].set_visible(True)
    ax.spines["bottom"].set_color(MK_GREY)
    ax.grid(axis="x"); ax.grid(axis="y", visible=False)
    section_label(ax, "Répartition des motifs de résiliation (%)")

    # ── 2. Heatmap saisonnalité ────────────────────────────────────────────
    ax2 = axes[1]
    MOIS = ["J","F","M","A","M","J","J","A","S","O","N","D"]
    heat = (panel[panel["resilie"]==1]
            .groupby(["annee","mois_resiliation"]).size().unstack(fill_value=0))
    heat.columns = MOIS
    # Normalisation par ligne (% du total annuel)
    heat_pct = heat.div(heat.sum(axis=1),axis=0)*100
    im = ax2.imshow(heat_pct.values, cmap=CMAP_MK, aspect="auto",
                    vmin=0, vmax=heat_pct.values.max())
    ax2.set_xticks(range(12)); ax2.set_xticklabels(MOIS, fontsize=8)
    ax2.set_yticks(range(len(ANNEES))); ax2.set_yticklabels(ANNEES, fontsize=8)
    for r in range(len(ANNEES)):
        for c in range(12):
            val = heat_pct.values[r,c]
            ax2.text(c, r, f"{val:.1f}", ha="center", va="center",
                     fontsize=7,
                     color=WHITE if val>8 else MK_GREY,
                     fontweight="bold" if val>heat_pct.values.max()*0.75 else "normal")
    ax2.spines["top"].set_visible(False); ax2.spines["right"].set_visible(False)
    ax2.spines["left"].set_visible(False); ax2.spines["bottom"].set_visible(True)
    cb = plt.colorbar(im, ax=ax2, shrink=0.7, pad=0.03)
    cb.set_label("% des résiliés annuels", fontsize=7, color=MK_GREY)
    cb.ax.tick_params(labelsize=7)
    section_label(ax2, "Saisonnalité mensuelle (% résiliés/an)")

    # ── 3. Évolution composition motifs ──────────────────────────────────
    ax3 = axes[2]
    top6 = df_r["motif_resiliation"].value_counts().head(6).index
    comp = (df_r[df_r["motif_resiliation"].isin(top6)]
            .groupby(["annee","motif_resiliation"]).size()
            .unstack(fill_value=0))
    comp_pct = comp.div(comp.sum(axis=1), axis=0)*100
    CC6 = [MK_NAVY, MK_BLUE, "#48CAE4", "#90E0EF", MK_ORANGE, MK_LGREY]
    bottom = np.zeros(len(comp_pct))
    for j, col in enumerate(comp_pct.columns):
        vals = comp_pct[col].values
        ax3.bar(comp_pct.index, vals, bottom=bottom,
                color=CC6[j], edgecolor=WHITE, linewidth=0.5,
                label=col, width=0.55)
        # Étiquette si > 6%
        for k, (v, b) in enumerate(zip(vals, bottom)):
            if v > 6:
                ax3.text(comp_pct.index[k], b+v/2, f"{v:.0f}%",
                         ha="center", va="center", fontsize=7,
                         color=WHITE if j<2 else MK_GREY, fontweight="bold")
        bottom += vals
    ax3.set_ylim(0,115)
    ax3.yaxis.set_major_formatter(mticker.FuncFormatter(lambda v,_: f"{v:.0f}%"))
    ax3.set_xticks(list(comp_pct.index))
    spine_clean(ax3)
    section_label(ax3, "Composition des motifs par année (%)")
    ax3.legend(fontsize=7, loc="lower center",
               bbox_to_anchor=(0.5,-0.28), ncol=2)

    plt.savefig(OUT + "03_motifs_saisonnalite.png")
    plt.close()
    print("✔ 03_motifs_saisonnalite.png")

fig03_motifs_saisonnalite(panel, bases)


