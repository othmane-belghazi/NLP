# B. COURBE DE LORENZ — CONCENTRATION DU CT (haut droit)
# ──────────────────────────────────────────────────────────────────────────────
ax = axes[0, 1]
ax.set_facecolor(BG)

def lorenz_curve(ct_vals, prime_an_vals):
    """Lorenz du CT : % cumulé de contrats vs % cumulé de surprime."""
    surprime = prime_an_vals * (ct_vals - 1)  # surprime = prime_ptf - prime_an
    idx = np.argsort(ct_vals)
    surprime_sorted = surprime[idx]
    cum_contrats = np.arange(1, len(ct_vals)+1) / len(ct_vals)
    cum_surprime = np.cumsum(surprime_sorted) / surprime_sorted.sum()
    return cum_contrats, cum_surprime

# Lorenz 80+
lx_old, ly_old = lorenz_curve(df_80["ct"].values, df_80["prime_an"].values)
lx_young, ly_young = lorenz_curve(df_young["ct"].values, df_young["prime_an"].values)

ax.plot(lx_old, ly_old, color=RED, linewidth=2.5, label="≥ 80 ans", zorder=4)
