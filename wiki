# ─── G12  Tableau de bord synthèse ───────────────────────────────────────────
def g12_synthese(df):
    fig, axes = plt.subplots(1, 2, figsize=(20, 8))
    fig.suptitle("Tableau de Bord Synthèse — Facteurs Explicatifs de la Résiliation")

    # A. Tableau statistique comparatif
    ax = axes[0]; ax.axis('off')
    vars_stat = [
        ('prime_comm',      "Prime comm. moy. (€)",   ".0f"),
        ('var_rel_prime',   "Variation prime moy. (%)",".1f"),
        ('bonus_malus',     "Bonus-Malus moyen",       ".3f"),
        ('anciennete',      "Ancienneté moy. (ans)",   ".1f"),
        ('nb_sin_total',    "Nb sinistres moyen",      ".2f"),
        ('score_pression',  "Score pression moyen",    ".3f"),
        ('age',             "Âge moyen",               ".1f"),
    ]
    d0 = df[df['resilie']==0]; d1 = df[df['resilie']==1]
    tbl = [["Variable", "Actifs", "Résiliés", "Écart", "Écart %"]]
    for var, lbl, fmt in vars_stat:
        m0 = d0[var].mean(); m1 = d1[var].mean()
        ec = m1 - m0
        ep = ec / abs(m0) * 100 if m0 != 0 else np.nan
        sign = '+' if ec > 0 else ''
        tbl.append([lbl,
                    f"{m0:{fmt}}",
                    f"{m1:{fmt}}",
                    f"{sign}{ec:{fmt}}",
                    f"{sign}{ep:.1f}%" if not pd.isna(ep) else "—"])

    t = ax.table(cellText=tbl[1:], colLabels=tbl[0], loc='center', cellLoc='center')
    t.auto_set_font_size(False); t.set_fontsize(9.5); t.scale(1.1, 1.65)
    for (r, c), cell in t.get_celld().items():
        cell.set_facecolor(BG3); cell.set_edgecolor(GRID)
        cell.set_text_props(color=TXT)
        if r == 0:
            cell.set_facecolor(BG); cell.set_text_props(color=JAUNE, fontweight='bold')
        if c in [3, 4] and r > 0:
            txt = cell.get_text().get_text()
            if txt.startswith('+'): cell.set_text_props(color=ROUGE, fontweight='bold')
            elif txt.startswith('-'): cell.set_text_props(color=VERT, fontweight='bold')
    ax.set_title("Statistiques comparatives Actifs vs Résiliés",
                 pad=20, fontsize=12, color=TXT)

    # B. Contribution relative de chaque facteur à la résiliation
    ax = axes[1]
    facteurs = [
        ('Hausse prime >15%',       df[df['var_rel_prime']>15]['resilie'].mean()*100),
        ('Franchit seuil 1 000€',   df[df['franchit_1000']==1]['resilie'].mean()*100),
        ('Franchit seuil 1 500€',   df[df['franchit_1500']==1]['resilie'].mean()*100),
        ('Malus fort (BM>1.75)',     df[df['bonus_malus']>1.75]['resilie'].mean()*100),
        ('Ancienneté <2 ans',        df[df['anciennete']<2]['resilie'].mean()*100),
        ('Sinistre responsable',     df[df['nb_sin_r_12m']>0]['resilie'].mean()*100),
        ('Cumul hausse >20%',        df[df['cumul_hausse_hist']>20]['resilie'].mean()*100
         if df['cumul_hausse_hist'].notna().sum()>100 else np.nan),
    ]
    tx_moy = df['resilie'].mean()*100
    facteurs_clean = [(l, v) for l, v in facteurs if not pd.isna(v)]
    facteurs_clean.sort(key=lambda x: x[1], reverse=True)
    lbls_f = [f[0] for f in facteurs_clean]
    vals_f = [f[1] for f in facteurs_clean]
    deltas = [v - tx_moy for v in vals_f]
    colors_f = [ROUGE if d > 0 else VERT for d in deltas]

    y_pos = range(len(lbls_f))
    ax.barh(y_pos, deltas, color=colors_f, height=0.55, alpha=0.88)
    ax.axvline(0, color=JAUNE, lw=1.8, alpha=0.7)
    ax.set_yticks(y_pos); ax.set_yticklabels(lbls_f, fontsize=10)
    ax.set_xlabel("Écart au taux moyen (points de %)")
    ax.set_title(f"Surcroît de résiliation par facteur\n(taux moyen : {tx_moy:.1f}%)")
    ax_clean(ax); ax.grid(axis='x', alpha=0.35)
    for i, (delta, val, c) in enumerate(zip(deltas, vals_f, colors_f)):
        sign = '+' if delta >= 0 else ''
        ax.text(delta + (0.1 if delta >= 0 else -0.1), i,
                f'{sign}{delta:.1f}pp → {val:.1f}%',
                va='center', ha='left' if delta >= 0 else 'right',
                fontsize=8.5, fontweight='bold', color=c)

    plt.tight_layout()
    sauvegarder(fig, "12_synthese_facteurs.png")

