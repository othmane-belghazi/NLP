# BLOC 3 — NETTOYAGE & TYPAGE
# ══════════════════════════════════════════════════════════════════════════════
def nettoyer(df: pd.DataFrame) -> pd.DataFrame:
    df = df.copy()

    # Dates
    for col in ['date_resil', 'date_terme']:
        if col in df.columns:
            df[col] = pd.to_datetime(df[col], errors='coerce')

    # Numériques
    for col in ['prime_comm', 'prime_comm_prec', 'bonus_malus',
                'age', 'anciennete', 'nb_sin_nr_12m', 'nb_sin_r_12m']:
        if col in df.columns:
            df[col] = pd.to_numeric(df[col], errors='coerce')

    # Catégorielles en majuscules propres
    for col in ['segment','canal','produit','region','classe_vehicule',
                'energie_vehicule','motif_resil']:
        if col in df.columns:
            df[col] = df[col].astype(str).str.strip().str.title()
            df[col] = df[col].replace({'Nan': np.nan, 'None': np.nan})

    # Doublons
    df = df.drop_duplicates(subset=['num_contrat','annee'])

    return df

