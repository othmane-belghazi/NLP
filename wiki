def mk_header(fig, title: str, insight: str, source: str = "Source : Portefeuille Auto 2022–2025"):
    """
    En-tête McKinsey : trait horizontal noir, TITRE EN MAJUSCULES,
    insight analytique en italique charbon, source en bas de figure.
    """
    # Trait supérieur bleu marine
    fig.add_artist(mlines.Line2D([0.0, 1.0], [1.005, 1.005],
                                  transform=fig.transFigure,
                                  color=MK_NAVY, linewidth=4, solid_capstyle="butt"))
    # Titre principal
    fig.text(0.0, 1.025, title.upper(), transform=fig.transFigure,
             fontsize=14, fontweight="bold", color=BLACK,
             fontfamily="Georgia", va="bottom")
    # Insight (headline analytique)
    fig.text(0.0, 1.005, insight, transform=fig.transFigure,
             fontsize=9, color=MK_GREY, style="italic", va="top")
    # Source en bas à gauche
    fig.text(0.0, -0.02, source, transform=fig.transFigure,
             fontsize=7, color=MK_LGREY, va="top")

def spine_clean(ax, keep_bottom=True):
    """Supprime les bords superflu (McKinsey : seulement axe x bas)."""
    ax.spines["top"].set_visible(False)
    ax.spines["right"].set_visible(False)
    ax.spines["left"].set_visible(False)
    ax.spines["bottom"].set_visible(keep_bottom)
    if keep_bottom:
        ax.spines["bottom"].set_color(MK_GREY)
        ax.spines["bottom"].set_linewidth(0.7)

def data_label(ax, val: float, x, y: float, fmt="{:.1f}%",
               color=BLACK, offset=3, fontsize=8):
    """Étiquette de données directement sur le graphique (pas de légende axe)."""
    ax.annotate(fmt.format(val), xy=(x, y),
                xytext=(0, offset), textcoords="offset points",
                ha="center", va="bottom", fontsize=fontsize,
                color=color, fontweight="bold", fontfamily="Georgia")

def section_label(ax, text: str):
    """Mini-titre de section en haut à gauche de l'axe."""
    ax.set_title(text, loc="left", fontsize=10, fontweight="bold",
                 color=BLACK, pad=8, fontfamily="Georgia")

