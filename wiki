# 4. GÉNÉRATION DES BASES SYNTHÉTIQUES
# ─────────────────────────────────────────────────────────────────────────────
def generate_base(annee, n, seed):
    rng = np.random.default_rng(seed)
    taux_base = {2022:0.10, 2023:0.12, 2024:0.14, 2025:0.15}[annee]

    produits   = ["Tiers Simple","Tiers Étendu","Tous Risques"]
    canaux     = ["Courtier","Direct","Comparateur","Agent"]
    segments   = ["Silver","Standard","Premium","Jeune Conducteur"]
    regions    = ["Île-de-France","PACA","Auvergne-Rhône-Alpes",
                  "Occitanie","Grand Est","Hauts-de-France","Bretagne"]
    energies   = ["Essence","Diesel","Électrique","Hybride"]
    fractions  = ["Annuel","Semestriel","Mensuel"]
    motifs     = ["Échéance principale","Loi Hamon","Résil. sinistre",
                  "Vente véhicule","Déménagement","Concurrence tarifaire"]

    age              = rng.integers(18,80,n)
    anciennete_cont  = rng.integers(0,25,n)
    anciennete_cli   = rng.integers(0,30,n)
    bonus_malus      = rng.uniform(0.5,1.5,n).round(2)
    prime_ttc_n1     = rng.uniform(300,2000,n).round(2)
    delta_mult       = {2022:0.02,2023:0.03,2024:0.07,2025:0.06}[annee]
    delta            = rng.normal(delta_mult,0.08,n)
    prime_ttc        = (prime_ttc_n1*(1+delta)).round(2)
    nb_sin           = rng.choice([0,0,0,1,1,2,3],n)
    nb_contrats      = rng.integers(1,5,n)
    indice_client    = rng.uniform(0,1,n).round(3)

    produit_arr  = rng.choice(produits,  n, p=[0.30,0.35,0.35])
    canal_arr    = rng.choice(canaux,    n, p=[0.40,0.25,0.25,0.10])
    segment_arr  = rng.choice(segments,  n, p=[0.25,0.40,0.25,0.10])
    region_arr   = rng.choice(regions,   n)
    energie_arr  = rng.choice(energies,  n, p=[0.40,0.35,0.10,0.15])
    fraction_arr = rng.choice(fractions, n, p=[0.45,0.30,0.25])

    logit = (taux_base
        + 0.04*(canal_arr=="Comparateur")
        + 0.03*(age<25).astype(float)
        + 0.03*(delta>0.10)
        + 0.02*(prime_ttc>1200)
        + 0.02*(nb_sin>=2)
        + 0.02*(segment_arr=="Jeune Conducteur")
        - 0.02*(anciennete_cont>10)
        - 0.02*(canal_arr=="Agent")
        + rng.normal(0,0.02,n))
    proba = np.clip(logit,0.01,0.95)
    resilie = (rng.uniform(0,1,n)<proba).astype(int)

    date_terme_arr = pd.to_datetime(
        [f"{annee}-{rng.integers(1,13):02d}-01" for _ in range(n)])
    date_resil_arr = []
    for i in range(n):
        if resilie[i]:
            m = rng.integers(1,13); d = rng.integers(1,29)
            date_resil_arr.append(pd.Timestamp(f"{annee}-{m:02d}-{d:02d}"))
        else:
            date_resil_arr.append(pd.NaT)

    motif_arr = []
    for i in range(n):
        if resilie[i]:
            if canal_arr[i]=="Comparateur":
                motif_arr.append(rng.choice(motifs,p=[0.15,0.15,0.10,0.15,0.10,0.35]))
            else:
                motif_arr.append(rng.choice(motifs,p=[0.30,0.20,0.15,0.15,0.10,0.10]))
        else:
            motif_arr.append(None)

    df = pd.DataFrame({
        "num_contrat"          : [f"C{annee}{i:06d}" for i in range(n)],
        "produit"              : produit_arr,
        "canal"                : canal_arr,
        "fractionnement"       : fraction_arr,
        "nb_contrats_retenus"  : nb_contrats,
        "anciennete_contrat"   : anciennete_cont,
        "segment_client"       : segment_arr,
        "age"                  : age,
        "indice_client"        : indice_client,
        "anciennete_client"    : anciennete_cli,
        "bonus_malus"          : bonus_malus,
        "region"               : region_arr,
        "nb_sinistres_resp_12m": nb_sin,
        "energie_voiture"      : energie_arr,
        "prime_ttc"            : prime_ttc,
        "prime_ttc_n1"         : prime_ttc_n1,
        "date_resiliation"     : date_resil_arr,
        "date_terme"           : date_terme_arr,
        "motif_resiliation"    : motif_arr,
        "annee"                : annee,
    })
    return df

def enrich(df, annee):
    df["annee"] = annee
    df["date_resiliation"] = pd.to_datetime(df["date_resiliation"], errors="coerce")
    df["resilie"]          = df["date_resiliation"].notna().astype(int)
    df["mois_resiliation"] = df["date_resiliation"].dt.month
    df["delta_prime"]      = df["prime_ttc"] - df["prime_ttc_n1"]
    df["delta_prime_pct"]  = df["delta_prime"] / df["prime_ttc_n1"].replace(0,np.nan) * 100

    df["tranche_age"] = pd.cut(df["age"],
        bins=[0,25,35,45,55,65,120],
        labels=["<25","25–35","35–45","45–55","55–65","65+"], right=False)
    df["tranche_prime"] = pd.cut(df["prime_ttc"],
        bins=[0,400,600,800,1000,1500,99999],
        labels=["<400","400–600","600–800","800–1000","1 000–1 500","1 500+"])
    df["anciennete_cl"] = pd.cut(df["anciennete_contrat"],
        bins=[0,2,5,10,99], right=False,
        labels=["0–2 ans","2–5 ans","5–10 ans","10+ ans"])
    df["cl_delta"] = pd.cut(df["delta_prime_pct"].clip(-50,80),
        bins=[-50,-10,-5,0,5,10,20,80],
        labels=["<-10%","-10/–5%","–5/0%","0/+5%","+5/+10%","+10/+20%",">+20%"])
    return df

