# BLOC 4 — FEATURE ENGINEERING (toutes les variables analytiques)
# ══════════════════════════════════════════════════════════════════════════════
def feature_engineering(df: pd.DataFrame) -> pd.DataFrame:
    df = df.copy()

    # ── 4.1  Variable cible ───────────────────────────────────────────────────
    df['resilie'] = df['date_resil'].notna().astype(int)

    # ── 4.2  Variation tarifaire terme courant ───────────────────────────────
    df['var_abs_prime'] = df['prime_comm'] - df['prime_comm_prec']
    df['var_rel_prime'] = np.where(
        df['prime_comm_prec'] > 0,
        (df['prime_comm'] - df['prime_comm_prec']) / df['prime_comm_prec'] * 100,
        np.nan)

    # ── 4.3  Catégorie de variation ──────────────────────────────────────────
    def cat_var(v):
        if pd.isna(v):      return 'Inconnu'
        if v < -5:          return 'Baisse >5%'
        if v < 0:           return 'Légère baisse'
        if v <= 3:          return 'Stable / +3%'
        if v <= 8:          return 'Hausse 3–8%'
        if v <= 15:         return 'Hausse 8–15%'
        if v <= 25:         return 'Hausse 15–25%'
        return              'Hausse >25%'

    df['cat_variation'] = df['var_rel_prime'].apply(cat_var)
    ordre_cat_var = ['Baisse >5%','Légère baisse','Stable / +3%',
                     'Hausse 3–8%','Hausse 8–15%','Hausse 15–25%','Hausse >25%','Inconnu']
    df['cat_variation'] = pd.Categorical(df['cat_variation'],
                                          categories=ordre_cat_var, ordered=True)

    # ── 4.4  Franchissement de seuils psychologiques ─────────────────────────
    df['franchit_1000'] = ((df['prime_comm'] >= 1000) &
                           (df['prime_comm_prec'] < 1000)).astype(int)
    df['franchit_1500'] = ((df['prime_comm'] >= 1500) &
                           (df['prime_comm_prec'] < 1500)).astype(int)
    df['franchit_2000'] = ((df['prime_comm'] >= 2000) &
                           (df['prime_comm_prec'] < 2000)).astype(int)

    # ── 4.5  Tranches de prime ────────────────────────────────────────────────
    bins_p  = [0, 400, 600, 800, 1000, 1200, 1500, 2000, 9999]
    lbls_p  = ['<400','400–600','600–800','800–1k','1k–1.2k','1.2k–1.5k','1.5k–2k','>2k']
    df['tranche_prime'] = pd.cut(df['prime_comm'], bins=bins_p,
                                  labels=lbls_p, right=True)

    # ── 4.6  Tranches d'âge ───────────────────────────────────────────────────
    bins_a = [0, 24, 34, 44, 54, 64, 120]
    lbls_a = ['18–24','25–34','35–44','45–54','55–64','65+']
    df['tranche_age'] = pd.cut(df['age'], bins=bins_a,
                                labels=lbls_a, right=True)

    # ── 4.7  Tranches d'ancienneté ────────────────────────────────────────────
    bins_anc = [-1, 0, 2, 5, 10, 99]
    lbls_anc = ['0 an','1–2 ans','3–5 ans','6–10 ans','>10 ans']
    df['tranche_anciennete'] = pd.cut(df['anciennete'], bins=bins_anc,
                                       labels=lbls_anc, right=True)

    # ── 4.8  Tranche bonus-malus ──────────────────────────────────────────────
    def cat_bm(b):
        if pd.isna(b):   return 'Inconnu'
        if b < 0.80:     return 'Bonus fort'
        if b < 1.00:     return 'Bonus'
        if b <= 1.00:    return 'Neutre'
        if b <= 1.25:    return 'Malus léger'
        if b <= 1.75:    return 'Malus modéré'
        return           'Malus fort'

    df['cat_bm'] = df['bonus_malus'].apply(cat_bm)
    df['cat_bm'] = pd.Categorical(df['cat_bm'],
        categories=['Bonus fort','Bonus','Neutre','Malus léger','Malus modéré','Malus fort','Inconnu'],
        ordered=True)

    # ── 4.9  Sinistralité totale & profil ────────────────────────────────────
    df['nb_sin_total'] = df['nb_sin_nr_12m'] + df['nb_sin_r_12m']
    df['profil_sin'] = np.where(df['nb_sin_total'] == 0,      'Sans sinistre',
                       np.where(df['nb_sin_r_12m'] == 0,      'NR seulement',
                       np.where(df['nb_sin_nr_12m'] == 0,     'R seulement',
                                                               'R + NR')))

    # ── 4.10  Mois du terme ───────────────────────────────────────────────────
    df['mois_terme'] = df['date_terme'].dt.month
    df['trim_terme'] = df['date_terme'].dt.quarter.map(
        {1:'T1 (Jan–Mar)', 2:'T2 (Avr–Jun)',
         3:'T3 (Jul–Sep)', 4:'T4 (Oct–Déc)'})

    # ── 4.11  Motif résiliation simplifié ────────────────────────────────────
    def simplif_motif(m):
        if pd.isna(m) or m in ['None','Nan']: return 'Non résilié'
        m = str(m).lower()
        if 'hamon' in m or 'loi' in m:       return 'Loi Hamon'
        if 'vente' in m or 'véhicule' in m:  return 'Vente véhicule'
        if 'paiement' in m or 'impayé' in m: return 'Non-paiement'
        if 'décès' in m or 'deces' in m:     return 'Décès'
        if 'assureur' in m or 'concurren' in m: return 'Autre assureur'
        if 'fin' in m:                        return 'Fin contrat'
        return 'Autre / Inconnu'

    df['motif_simplifie'] = df['motif_resil'].apply(simplif_motif)

    # ── 4.12  Score de pression tarifaire ────────────────────────────────────
    # Combinaison normalisée : variation + niveau prime + sinistralité
    vr_norm = df['var_rel_prime'].clip(-30, 50).fillna(0) / 50
    pr_norm = df['prime_comm'].clip(300, 2500) / 2500
    sin_norm = df['nb_sin_total'].clip(0, 5) / 5
    df['score_pression'] = (vr_norm * 0.50 + pr_norm * 0.35 + sin_norm * 0.15).round(4)

    # ── 4.13  Catégorie de risque composite ──────────────────────────────────
    def cat_risque(row):
        score = 0
        if not pd.isna(row['var_rel_prime']):
            if row['var_rel_prime'] > 15: score += 3
            elif row['var_rel_prime'] > 8: score += 2
            elif row['var_rel_prime'] > 3: score += 1
        if row['prime_comm'] > 1500: score += 2
        elif row['prime_comm'] > 1000: score += 1
        if row['anciennete'] < 2: score += 1
        if row['nb_sin_r_12m'] > 0: score += 1
        if row['bonus_malus'] > 1.5: score += 1
        if score <= 1:   return 'Risque faible'
        if score <= 3:   return 'Risque modéré'
        if score <= 5:   return 'Risque élevé'
        return           'Risque très élevé'

    df['cat_risque'] = df.apply(cat_risque, axis=1)
    df['cat_risque'] = pd.Categorical(df['cat_risque'],
        categories=['Risque faible','Risque modéré','Risque élevé','Risque très élevé'],
        ordered=True)

    # ── 4.14  Historique inter-annuel (effet cumul entre années) ─────────────
    # Pour chaque contrat présent sur plusieurs années, on calcule la hausse cumulée
    df = df.sort_values(['num_contrat','annee']).reset_index(drop=True)

    # Construire base contrat-niveau pour récupérer historique
    hist = df[['num_contrat','annee','var_rel_prime']].copy()
    hist_pivot = hist.pivot_table(index='num_contrat', columns='annee',
                                  values='var_rel_prime', aggfunc='first')

    annees_dispo = sorted([c for c in hist_pivot.columns if isinstance(c, int)])

    # Cumul hausse sur les années précédentes (pour contrats présents plusieurs années)
    for i, annee in enumerate(annees_dispo):
        if i == 0:
            hist_pivot[f'cumul_hausse_{annee}'] = np.nan
        else:
            cols_prec = annees_dispo[:i]
            cumul = hist_pivot[cols_prec].clip(lower=0).sum(axis=1, skipna=True)
            nb_obs = hist_pivot[cols_prec].notna().sum(axis=1)
            hist_pivot[f'cumul_hausse_{annee}'] = np.where(nb_obs > 0, cumul, np.nan)

    hist_pivot = hist_pivot.reset_index()
    cumul_cols = [c for c in hist_pivot.columns if str(c).startswith('cumul_hausse_')]
    df = df.merge(hist_pivot[['num_contrat'] + cumul_cols], on='num_contrat', how='left')

    # Variable synthétique cumul pour l'année du terme
    def get_cumul(row):
        col = f'cumul_hausse_{int(row["annee"])}'
        return row[col] if col in row.index and not pd.isna(row[col]) else np.nan

    df['cumul_hausse_hist'] = df.apply(get_cumul, axis=1)

    # Catégorie de cumul
    def cat_cumul(v):
        if pd.isna(v) or v == 0: return 'Aucune hausse historique'
        if v <= 5:   return 'Cumul 0–5%'
        if v <= 10:  return 'Cumul 5–10%'
        if v <= 20:  return 'Cumul 10–20%'
        if v <= 35:  return 'Cumul 20–35%'
        return       'Cumul >35%'

    df['cat_cumul'] = df['cumul_hausse_hist'].apply(cat_cumul)
    df['cat_cumul'] = pd.Categorical(df['cat_cumul'],
        categories=['Aucune hausse historique','Cumul 0–5%','Cumul 5–10%',
                    'Cumul 10–20%','Cumul 20–35%','Cumul >35%'], ordered=True)

    # ── 4.15  Flag multi-années (contrat observé sur plusieurs termes) ────────
    nb_termes = df.groupby('num_contrat')['annee'].count()
    df['nb_termes_obs'] = df['num_contrat'].map(nb_termes)
    df['multi_annees']  = (df['nb_termes_obs'] > 1).astype(int)

    # ── 4.16  Nettoyage colonnes temporaires ─────────────────────────────────
    df = df.drop(columns=cumul_cols, errors='ignore')

    return df

