# FIGURE 02 — WATERFALL + DÉCOMPOSITION PAR CANAL
# ═════════════════════════════════════════════════════════════════════════════
def fig02_waterfall_canal(M, panel):
    fig, axes = plt.subplots(1, 2, figsize=(16, 7),
                              gridspec_kw={"width_ratios":[1.2,1]})
    fig.subplots_adjust(left=0.06, right=0.97, top=0.82, bottom=0.12, wspace=0.35)
    mk_header(fig,
        "Décomposition de la variation du taux — Waterfall & Canal",
        "La hausse de 2024 (+2,5 pp) coïncide avec le pic inflationniste ; le canal Comparateur affiche un taux structurellement supérieur")

    # ── Waterfall ─────────────────────────────────────────────────────────
    ax = axes[0]
    taux  = M["taux"].values
    years = list(M.index)
    running = taux[0]
    bottoms = [0]; heights = [taux[0]]; colors_ = [MK_NAVY]; labels_ = [str(years[0])]
    for i in range(1, len(years)):
        d = taux[i] - taux[i-1]
        bottoms.append(running if d>0 else running+d)
        heights.append(abs(d))
        colors_.append(MK_RED if d>0 else MK_GREEN)
        labels_.append(str(years[i]))
        running += d
    x_pos = np.arange(len(years))
    bars = ax.bar(x_pos, heights, bottom=bottoms, color=colors_,
                  edgecolor="none", width=0.55, zorder=3)

    # Connecteurs (lignes horizontales de liaison)
    r = taux[0]
    for i in range(1, len(years)):
        d = taux[i]-taux[i-1]
        ax.plot([i-1+0.275, i-0.275], [r,r], color=MK_LGREY,
                linewidth=0.8, linestyle="--", zorder=4)
        r += d

    for i, (bot, h, c) in enumerate(zip(bottoms, heights, colors_)):
        top = bot+h
        sign = "" if i==0 else ("▲" if colors_[i]==MK_RED else "▼")
        val  = taux[0] if i==0 else taux[i]-taux[i-1]
        ax.text(i, top+0.12, f"{sign}{abs(val):.2f} pp",
                ha="center", va="bottom", fontsize=9,
                color=c if i>0 else MK_NAVY, fontweight="bold")

    ax.set_xticks(x_pos); ax.set_xticklabels(years)
    ax.set_ylim(0, max(taux)*1.4)
    ax.yaxis.set_major_formatter(mticker.FuncFormatter(lambda v,_: f"{v:.0f}%"))
    spine_clean(ax)
    section_label(ax, "Variation annuelle du taux de résiliation (pp)")
    ax.legend(handles=[
        mpatches.Patch(color=MK_NAVY, label="Base"),
        mpatches.Patch(color=MK_RED,  label="Hausse"),
        mpatches.Patch(color=MK_GREEN,label="Baisse")], fontsize=8)

    # ── Taux par canal × année ────────────────────────────────────────────
    ax2 = axes[1]
    tmp = (panel.groupby(["annee","canal"], observed=True)["resilie"]
           .mean()*100).reset_index()
    tmp.columns = ["annee","canal","taux"]
    canaux_ord = (tmp.groupby("canal")["taux"].mean()
                  .sort_values(ascending=False).index)
    CC = [MK_NAVY, MK_BLUE, "#48CAE4", MK_LGREY]

    for j, canal in enumerate(canaux_ord):
        sub = tmp[tmp["canal"]==canal]
        ax2.plot(sub["annee"], sub["taux"], marker="o",
                 color=CC[j], linewidth=2.2, markersize=7,
                 markerfacecolor=WHITE, markeredgecolor=CC[j],
                 markeredgewidth=2, label=canal)
