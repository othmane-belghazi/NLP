    n = len(df); nr = df['resilie'].sum(); tx = nr/n*100
    print(f"\n{'='*65}")
    print(f"  STATISTIQUES GÉNÉRALES")
    print(f"{'='*65}")
    print(f"  Termes totaux       : {n:>10,}")
    print(f"  Contrats uniques    : {df['num_contrat'].nunique():>10,}")
    print(f"  Résiliés            : {nr:>10,}  ({tx:.2f}%)")
    print(f"  Années couvertes    : {sorted(df['annee'].unique())}")
    print(f"\n  Taux de résiliation par année :")
    for yr, g in df.groupby('annee'):
        print(f"    {yr} : {g['resilie'].mean()*100:.2f}%  (n={len(g):,})")
    print(f"\n  Taux de résiliation par segment :")
    for seg, g in df.groupby('segment'):
        print(f"    {seg:<8}: {g['resilie'].mean()*100:.2f}%  (n={len(g):,})")
    print(f"\n  Prime commerciale :")
    print(f"    Moyenne  : {df['prime_comm'].mean():.2f} €")
    print(f"    Médiane  : {df['prime_comm'].median():.2f} €")
    print(f"    Min/Max  : {df['prime_comm'].min():.2f} € / {df['prime_comm'].max():.2f} €")
    print(f"\n  Variation tarifaire (var_rel_prime) :")
    print(f"    Moyenne  : {df['var_rel_prime'].mean():.2f}%")
    print(f"    Médiane  : {df['var_rel_prime'].median():.2f}%")
    print()

