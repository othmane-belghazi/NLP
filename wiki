"""
=============================================================================
PIPELINE PYSPARK - ANALYSE DES RÉSILIATIONS ASSURANCE AUTO
=============================================================================
Objectifs:
  1. Jointure base 2025 (résiliés) avec bases 2024/2023/2022 (historique tarifaire)
  2. Feature Engineering: effet cumul majorations, seuils psychologiques, écarts
  3. Clustering des profils résiliés
=============================================================================
"""

from pyspark.sql import SparkSession
from pyspark.sql import functions as F
from pyspark.sql.window import Window
from pyspark.sql.types import *
from pyspark.ml.feature import VectorAssembler, StandardScaler
from pyspark.ml.clustering import KMeans
from pyspark.ml import Pipeline

# ─────────────────────────────────────────────────────────────────────────────
# 0. INITIALISATION SPARK
# ─────────────────────────────────────────────────────────────────────────────
spark = SparkSession.builder \
    .appName("Resiliation_Auto_Analysis") \
    .config("spark.sql.shuffle.partitions", "200") \
    .getOrCreate()

# ─────────────────────────────────────────────────────────────────────────────
# 1. CHARGEMENT DES BASES
# ─────────────────────────────────────────────────────────────────────────────
# Adapter les chemins selon votre environnement
base_2025 = spark.read.parquet("hdfs:///data/auto/base_resilies_2025.parquet")
base_2024 = spark.read.parquet("hdfs:///data/auto/base_portefeuille_2024.parquet")
base_2023 = spark.read.parquet("hdfs:///data/auto/base_portefeuille_2023.parquet")
base_2022 = spark.read.parquet("hdfs:///data/auto/base_portefeuille_2022.parquet")

# Colonnes attendues communes:
# id_client, prime_proposee, prime_avant (prime précédente), bonus_malus,
# age_conducteur, anciennete_permis, type_vehicule, puissance_fiscale,
# zone_geographique, nb_sinistres, mode_paiement, fractionnement, ...

# ─────────────────────────────────────────────────────────────────────────────
# 2. JOINTURE HISTORIQUE TARIFAIRE (LEFT JOIN)
# ─────────────────────────────────────────────────────────────────────────────
# Sélectionner uniquement les colonnes tarifaires des bases historiques
cols_tarif = ["id_client", "prime_proposee", "prime_avant", "bonus_malus"]

hist_2024 = base_2024.select(
    [F.col(c).alias(f"{c}_2024") if c != "id_client" else F.col(c) for c in cols_tarif]
)
hist_2023 = base_2023.select(
    [F.col(c).alias(f"{c}_2023") if c != "id_client" else F.col(c) for c in cols_tarif]
)
hist_2022 = base_2022.select(
    [F.col(c).alias(f"{c}_2022") if c != "id_client" else F.col(c) for c in cols_tarif]
)

# Jointures LEFT pour garder tous les résiliés 2025
# (les nouveaux clients n'auront pas de correspondance => null)
df = base_2025.alias("b25") \
    .join(hist_2024.alias("h24"), "id_client", "left") \
    .join(hist_2023.alias("h23"), "id_client", "left") \
    .join(hist_2022.alias("h22"), "id_client", "left")

# Flag: nouveau client (pas trouvé dans les bases antérieures)
df = df.withColumn(
    "is_nouveau_client",
    F.when(
        F.col("prime_proposee_2024").isNull() &
        F.col("prime_proposee_2023").isNull() &
        F.col("prime_proposee_2022").isNull(),
        1
    ).otherwise(0)
)

# ─────────────────────────────────────────────────────────────────────────────
# 3. FEATURE ENGINEERING - VARIABLES TARIFAIRES DYNAMIQUES
# ─────────────────────────────────────────────────────────────────────────────

# --- 3A. MAJORATIONS ANNUELLES (en euros et en %) ---
df = df.withColumn(
    "majoration_2023_2024",
    F.when(F.col("prime_proposee_2023").isNotNull(),
           F.col("prime_proposee_2024") - F.col("prime_proposee_2023"))
).withColumn(
    "majoration_2024_2025",
    F.when(F.col("prime_proposee_2024").isNotNull(),
           F.col("prime_proposee") - F.col("prime_proposee_2024"))
).withColumn(
    "majoration_2022_2023",
    F.when(F.col("prime_proposee_2022").isNotNull(),
           F.col("prime_proposee_2023") - F.col("prime_proposee_2022"))
)

# Majorations en pourcentage
df = df.withColumn(
    "pct_majoration_2024_2025",
    F.when(F.col("prime_proposee_2024") > 0,
           (F.col("prime_proposee") - F.col("prime_proposee_2024")) / F.col("prime_proposee_2024") * 100)
).withColumn(
    "pct_majoration_2023_2024",
    F.when(F.col("prime_proposee_2023") > 0,
           (F.col("prime_proposee_2024") - F.col("prime_proposee_2023")) / F.col("prime_proposee_2023") * 100)
).withColumn(
    "pct_majoration_2022_2023",
    F.when(F.col("prime_proposee_2022") > 0,
           (F.col("prime_proposee_2023") - F.col("prime_proposee_2022")) / F.col("prime_proposee_2022") * 100)
)

# --- 3B. EFFET CUMUL DES MAJORATIONS ---
# Nombre d'années consécutives avec majoration
df = df.withColumn(
    "nb_annees_hausse_consecutive",
    (F.when(F.col("majoration_2024_2025") > 0, 1).otherwise(0) +
     F.when(F.col("majoration_2023_2024") > 0, 1).otherwise(0) +
     F.when(F.col("majoration_2022_2023") > 0, 1).otherwise(0))
)

# Cumul total de majoration depuis la première prime connue
df = df.withColumn(
    "premiere_prime_connue",
    F.coalesce(
        F.col("prime_proposee_2022"),
        F.col("prime_proposee_2023"),
        F.col("prime_proposee_2024"),
        F.col("prime_proposee")
    )
)

df = df.withColumn(
    "cumul_majoration_totale_euros",
    F.col("prime_proposee") - F.col("premiere_prime_connue")
)

df = df.withColumn(
    "cumul_majoration_totale_pct",
    F.when(F.col("premiere_prime_connue") > 0,
           (F.col("prime_proposee") - F.col("premiere_prime_connue")) / F.col("premiere_prime_connue") * 100)
)

# Accélération de la hausse (hausse dernière année vs hausse année précédente)
df = df.withColumn(
    "acceleration_hausse",
    F.when(
        F.col("majoration_2023_2024").isNotNull() & (F.col("majoration_2023_2024") != 0),
        F.col("majoration_2024_2025") / F.abs(F.col("majoration_2023_2024"))
    )
)

# Score de pression tarifaire (pondéré par récence)
df = df.withColumn(
    "score_pression_tarifaire",
    (F.coalesce(F.col("pct_majoration_2024_2025"), F.lit(0)) * 3 +
     F.coalesce(F.col("pct_majoration_2023_2024"), F.lit(0)) * 2 +
     F.coalesce(F.col("pct_majoration_2022_2023"), F.lit(0)) * 1) / 6
)

# --- 3C. EFFET PSYCHOLOGIQUE - PASSAGE EN CENTAINE D'EUROS ---
# Centaine de la prime actuelle vs centaine de la prime précédente
df = df.withColumn(
    "centaine_prime_2025",
    F.floor(F.col("prime_proposee") / 100) * 100
).withColumn(
    "centaine_prime_2024",
    F.when(F.col("prime_proposee_2024").isNotNull(),
           F.floor(F.col("prime_proposee_2024") / 100) * 100)
)

# Flag: franchissement d'un seuil de centaine
df = df.withColumn(
    "franchissement_centaine",
    F.when(
        F.col("centaine_prime_2024").isNotNull() &
        (F.col("centaine_prime_2025") > F.col("centaine_prime_2024")),
        1
    ).otherwise(0)
)

# Nombre de centaines franchies
df = df.withColumn(
    "nb_centaines_franchies",
    F.when(
        F.col("centaine_prime_2024").isNotNull(),
        (F.col("centaine_prime_2025") - F.col("centaine_prime_2024")) / 100
    ).otherwise(0).cast("int")
)

# Proximité au seuil supérieur (combien manque pour la prochaine centaine)
df = df.withColumn(
    "distance_prochaine_centaine",
    (F.ceil(F.col("prime_proposee") / 100) * 100) - F.col("prime_proposee")
)

# Flag: prime juste au-dessus d'un seuil (0-15€ au-dessus)
df = df.withColumn(
    "juste_au_dessus_seuil",
    F.when(
        (F.col("prime_proposee") % 100 <= 15) & (F.col("prime_proposee") % 100 > 0),
        1
    ).otherwise(0)
)

# --- 3D. ÉCART PREMIÈRE PRIME TROUVÉE vs DERNIÈRE PROPOSÉE ---
df = df.withColumn(
    "ecart_premiere_derniere_euros",
    F.col("prime_proposee") - F.col("premiere_prime_connue")
)

df = df.withColumn(
    "ecart_premiere_derniere_pct",
    F.when(F.col("premiere_prime_connue") > 0,
           (F.col("prime_proposee") - F.col("premiere_prime_connue")) / F.col("premiere_prime_connue") * 100)
)

# Ratio prime actuelle / première prime
df = df.withColumn(
    "ratio_prime_actuelle_premiere",
    F.when(F.col("premiere_prime_connue") > 0,
           F.col("prime_proposee") / F.col("premiere_prime_connue"))
)

# --- 3E. VARIABLES DE PROFIL ENRICHIES ---
# Tranche de prime (buckets)
df = df.withColumn(
    "tranche_prime",
    F.when(F.col("prime_proposee") < 300, "< 300€")
     .when(F.col("prime_proposee") < 500, "300-500€")
     .when(F.col("prime_proposee") < 700, "500-700€")
     .when(F.col("prime_proposee") < 1000, "700-1000€")
     .otherwise(">= 1000€")
)

# Ancienneté dans le portefeuille (nb d'années retrouvées)
df = df.withColumn(
    "anciennete_portefeuille",
    (F.when(F.col("prime_proposee_2024").isNotNull(), 1).otherwise(0) +
     F.when(F.col("prime_proposee_2023").isNotNull(), 1).otherwise(0) +
     F.when(F.col("prime_proposee_2022").isNotNull(), 1).otherwise(0))
)

# Volatilité tarifaire (écart-type des majorations)
df = df.withColumn(
    "volatilite_tarifaire",
    F.sqrt(
        (F.pow(F.coalesce(F.col("pct_majoration_2024_2025"), F.lit(0)) -
               F.col("score_pression_tarifaire"), 2) +
         F.pow(F.coalesce(F.col("pct_majoration_2023_2024"), F.lit(0)) -
               F.col("score_pression_tarifaire"), 2) +
         F.pow(F.coalesce(F.col("pct_majoration_2022_2023"), F.lit(0)) -
               F.col("score_pression_tarifaire"), 2)) / 3
    )
)

# ─────────────────────────────────────────────────────────────────────────────
# 4. CLUSTERING (PySpark ML)
# ─────────────────────────────────────────────────────────────────────────────

# Variables pour le clustering
feature_cols = [
    "prime_proposee",
    "bonus_malus",
    "cumul_majoration_totale_pct",
    "nb_annees_hausse_consecutive",
    "score_pression_tarifaire",
    "franchissement_centaine",
    "ecart_premiere_derniere_pct",
    "anciennete_portefeuille",
    "volatilite_tarifaire",
    "age_conducteur",
    "nb_sinistres"
]

# Remplacer les nulls par 0 pour le clustering
for col_name in feature_cols:
    df = df.withColumn(col_name, F.coalesce(F.col(col_name), F.lit(0)))

# Pipeline ML
assembler = VectorAssembler(inputCols=feature_cols, outputCol="features_raw")
scaler = StandardScaler(inputCol="features_raw", outputCol="features", withMean=True, withStd=True)
kmeans = KMeans(featuresCol="features", predictionCol="cluster", k=4, seed=42, maxIter=50)

pipeline = Pipeline(stages=[assembler, scaler, kmeans])
model = pipeline.fit(df)
df_clustered = model.transform(df)

# ─────────────────────────────────────────────────────────────────────────────
# 5. ANALYSE DES CLUSTERS
# ─────────────────────────────────────────────────────────────────────────────

# Profil moyen par cluster
cluster_profile = df_clustered.groupBy("cluster").agg(
    F.count("*").alias("nb_clients"),
    F.round(F.avg("prime_proposee"), 2).alias("prime_moy"),
    F.round(F.avg("cumul_majoration_totale_pct"), 2).alias("cumul_majo_pct_moy"),
    F.round(F.avg("nb_annees_hausse_consecutive"), 2).alias("nb_hausse_consec_moy"),
    F.round(F.avg("score_pression_tarifaire"), 2).alias("pression_tarif_moy"),
    F.round(F.avg("franchissement_centaine"), 2).alias("taux_franchissement"),
    F.round(F.avg("ecart_premiere_derniere_pct"), 2).alias("ecart_1ere_derniere_moy"),
    F.round(F.avg("anciennete_portefeuille"), 2).alias("anciennete_moy"),
    F.round(F.avg("bonus_malus"), 2).alias("bm_moyen"),
    F.round(F.avg("age_conducteur"), 2).alias("age_moyen"),
    F.round(F.avg("nb_sinistres"), 2).alias("sinistres_moy"),
)

############################

"""
=============================================================================
SIMULATION PANDAS - ANALYSE RÉSILIATIONS AUTO AVEC DONNÉES DE TEST
=============================================================================
"""
import numpy as np
import pandas as pd
import matplotlib
matplotlib.use('Agg')
import matplotlib.pyplot as plt
import matplotlib.gridspec as gridspec
from matplotlib.patches import FancyBboxPatch
import seaborn as sns
from sklearn.preprocessing import StandardScaler
from sklearn.cluster import KMeans
from sklearn.decomposition import PCA
from sklearn.metrics import silhouette_score, silhouette_samples
import warnings
warnings.filterwarnings('ignore')

np.random.seed(42)

# ─────────────────────────────────────────────────────────────────────────────
# 1. GÉNÉRATION DES DONNÉES DE TEST
# ─────────────────────────────────────────────────────────────────────────────

N = 2000  # résiliés 2025

# Identifiants
ids = [f"CLI_{i:05d}" for i in range(N)]

# Profils clients
age_conducteur = np.random.choice(
    [np.random.randint(18, 30), np.random.randint(30, 55), np.random.randint(55, 80)],
    size=N, p=[0.25, 0.50, 0.25]
)
anciennete_permis = np.clip(age_conducteur - 18 + np.random.randint(-2, 5, N), 0, 60)
bonus_malus = np.random.choice(
    [0.50, 0.56, 0.60, 0.64, 0.68, 0.72, 0.76, 0.80, 0.85, 0.90, 0.95, 1.00,
     1.10, 1.25, 1.50, 1.75, 2.00, 2.50, 3.00, 3.50],
    size=N, p=[0.12, 0.05, 0.06, 0.05, 0.05, 0.05, 0.04, 0.04, 0.04, 0.05,
               0.05, 0.10, 0.07, 0.06, 0.05, 0.03, 0.03, 0.02, 0.02, 0.02]
)
nb_sinistres = np.random.choice([0, 1, 2, 3, 4], size=N, p=[0.45, 0.30, 0.15, 0.07, 0.03])
zone_geo = np.random.choice(["A", "B", "C", "D", "E"], size=N, p=[0.15, 0.25, 0.30, 0.20, 0.10])
type_vehicule = np.random.choice(
    ["Citadine", "Berline", "SUV", "Utilitaire", "Sport"],
    size=N, p=[0.30, 0.25, 0.20, 0.15, 0.10]
)
puissance_fiscale = np.random.choice(range(3, 16), size=N)
mode_paiement = np.random.choice(["Mensuel", "Trimestriel", "Annuel"], size=N, p=[0.55, 0.25, 0.20])

# ─── Primes historiques (logique réaliste) ───
# Base prime liée au BM et à la zone
base_prime = 280 + bonus_malus * 200 + puissance_fiscale * 12
zone_coeff = {"A": 1.3, "B": 1.15, "C": 1.0, "D": 0.9, "E": 0.85}
zone_mult = np.array([zone_coeff[z] for z in zone_geo])
base_prime = base_prime * zone_mult

# ~30% sont nouveaux clients (pas d'historique avant 2025)
is_nouveau = np.random.choice([0, 1], size=N, p=[0.70, 0.30])

# Générer primes historiques avec tendances de hausse variées
prime_2022 = np.where(is_nouveau == 0,
    np.round(base_prime * np.random.uniform(0.70, 0.90, N), 2),
    np.nan)

# ~15% perdus entre 2022 et 2023
lost_2023 = (is_nouveau == 0) & (np.random.random(N) < 0.15)
prime_2023 = np.where(
    (is_nouveau == 0) & ~lost_2023,
    np.where(~np.isnan(prime_2022),
             np.round(prime_2022 * np.random.uniform(1.00, 1.12, N), 2),
             np.round(base_prime * np.random.uniform(0.75, 0.92, N), 2)),
    np.nan)

lost_2024 = (is_nouveau == 0) & np.isnan(prime_2023) & (np.random.random(N) < 0.10)
prime_2024 = np.where(
    (is_nouveau == 0) & ~lost_2024,
    np.where(~np.isnan(prime_2023),
             np.round(prime_2023 * np.random.uniform(1.01, 1.15, N), 2),
             np.where(~np.isnan(prime_2022),
                       np.round(prime_2022 * np.random.uniform(1.05, 1.20, N), 2),
                       np.nan)),
    np.nan)

# Prime 2025 (la dernière proposée avant résiliation)
prime_2025 = np.where(
    ~np.isnan(prime_2024),
    np.round(prime_2024 * np.random.uniform(1.02, 1.20, N), 2),
    np.round(base_prime * np.random.uniform(0.90, 1.15, N), 2)
)

# Prime avant (la prime avant renouvellement en 2025)
prime_avant = np.where(~np.isnan(prime_2024), prime_2024, prime_2025 * np.random.uniform(0.85, 0.98, N))

# ─── Construction du DataFrame 2025 ───
df_2025 = pd.DataFrame({
    "id_client": ids,
    "prime_proposee": np.round(prime_2025, 2),
    "prime_avant": np.round(prime_avant, 2),
    "bonus_malus": bonus_malus,
    "age_conducteur": age_conducteur,
    "anciennete_permis": anciennete_permis,
    "nb_sinistres": nb_sinistres,
    "zone_geo": zone_geo,
    "type_vehicule": type_vehicule,
    "puissance_fiscale": puissance_fiscale,
    "mode_paiement": mode_paiement,
})

df_hist_2024 = pd.DataFrame({
    "id_client": ids,
    "prime_proposee_2024": prime_2024,
    "bonus_malus_2024": np.where(~np.isnan(prime_2024), bonus_malus * np.random.uniform(0.90, 1.05, N), np.nan),
})
df_hist_2023 = pd.DataFrame({
    "id_client": ids,
    "prime_proposee_2023": prime_2023,
    "bonus_malus_2023": np.where(~np.isnan(prime_2023), bonus_malus * np.random.uniform(0.85, 1.02, N), np.nan),
})
df_hist_2022 = pd.DataFrame({
    "id_client": ids,
    "prime_proposee_2022": prime_2022,
    "bonus_malus_2022": np.where(~np.isnan(prime_2022), bonus_malus * np.random.uniform(0.80, 1.00, N), np.nan),
})

print(f"Base 2025 (résiliés): {len(df_2025)} lignes")
print(f"Historique 2024 disponible: {df_hist_2024['prime_proposee_2024'].notna().sum()}")
print(f"Historique 2023 disponible: {df_hist_2023['prime_proposee_2023'].notna().sum()}")
print(f"Historique 2022 disponible: {df_hist_2022['prime_proposee_2022'].notna().sum()}")

# ─────────────────────────────────────────────────────────────────────────────
# 2. JOINTURES (équivalent PySpark LEFT JOIN)
# ─────────────────────────────────────────────────────────────────────────────
df = df_2025.merge(df_hist_2024, on="id_client", how="left") \
            .merge(df_hist_2023, on="id_client", how="left") \
            .merge(df_hist_2022, on="id_client", how="left")

df["is_nouveau_client"] = (
    df["prime_proposee_2024"].isna() &
    df["prime_proposee_2023"].isna() &
    df["prime_proposee_2022"].isna()
).astype(int)

print(f"\nNouveaux clients: {df['is_nouveau_client'].sum()} ({df['is_nouveau_client'].mean()*100:.1f}%)")

# ─────────────────────────────────────────────────────────────────────────────
# 3. FEATURE ENGINEERING
# ─────────────────────────────────────────────────────────────────────────────

# --- 3A. MAJORATIONS ANNUELLES ---
df["majoration_2022_2023"] = df["prime_proposee_2023"] - df["prime_proposee_2022"]
df["majoration_2023_2024"] = df["prime_proposee_2024"] - df["prime_proposee_2023"]
df["majoration_2024_2025"] = df["prime_proposee"] - df["prime_proposee_2024"]

df["pct_majoration_2022_2023"] = (df["majoration_2022_2023"] / df["prime_proposee_2022"]) * 100
df["pct_majoration_2023_2024"] = (df["majoration_2023_2024"] / df["prime_proposee_2023"]) * 100
df["pct_majoration_2024_2025"] = (df["majoration_2024_2025"] / df["prime_proposee_2024"]) * 100

# --- 3B. EFFET CUMUL ---
df["nb_annees_hausse_consecutive"] = (
    (df["majoration_2024_2025"].fillna(0) > 0).astype(int) +
    (df["majoration_2023_2024"].fillna(0) > 0).astype(int) +
    (df["majoration_2022_2023"].fillna(0) > 0).astype(int)
)

df["premiere_prime_connue"] = df[["prime_proposee_2022", "prime_proposee_2023",
                                   "prime_proposee_2024", "prime_proposee"]].bfill(axis=1).iloc[:, 0]

df["cumul_majoration_totale_euros"] = df["prime_proposee"] - df["premiere_prime_connue"]
df["cumul_majoration_totale_pct"] = np.where(
    df["premiere_prime_connue"] > 0,
    (df["prime_proposee"] - df["premiere_prime_connue"]) / df["premiere_prime_connue"] * 100,
    0
)

# Accélération de la hausse
df["acceleration_hausse"] = np.where(
    (df["majoration_2023_2024"].notna()) & (df["majoration_2023_2024"].abs() > 0),
    df["majoration_2024_2025"] / df["majoration_2023_2024"].abs(),
    np.nan
)

# Score de pression tarifaire (pondéré par récence)
df["score_pression_tarifaire"] = (
    df["pct_majoration_2024_2025"].fillna(0) * 3 +
    df["pct_majoration_2023_2024"].fillna(0) * 2 +
    df["pct_majoration_2022_2023"].fillna(0) * 1
) / 6

# --- 3C. EFFET PSYCHOLOGIQUE - SEUILS CENTAINES ---
df["centaine_prime_2025"] = (df["prime_proposee"] // 100) * 100
df["centaine_prime_2024"] = np.where(
    df["prime_proposee_2024"].notna(),
    (df["prime_proposee_2024"] // 100) * 100,
    np.nan
)

df["franchissement_centaine"] = np.where(
    df["centaine_prime_2024"].notna() & (df["centaine_prime_2025"] > df["centaine_prime_2024"]),
    1, 0
)

nb_cent = np.where(
    df["centaine_prime_2024"].notna(),
