# FIGURE 08 — SYNTHÈSE STRATÉGIQUE : MATRICE RISQUE × VOLUME
# ═════════════════════════════════════════════════════════════════════════════
def fig08_matrice_strategique(panel):
    """
    Matrice 2×2 McKinsey : axe X = taux de résiliation, axe Y = volume de contrats.
    Chaque point = un segment (canal × produit). Taille = prime moyenne.
    Quadrants : Surveiller | Priorité absolue | Stable | Optimiser.
    """
    fig, ax = plt.subplots(figsize=(14, 9))
    fig.subplots_adjust(left=0.10, right=0.88, top=0.82, bottom=0.12)
    mk_header(fig,
        "Matrice Stratégique de Risque de Résiliation",
        "Positionnement des segments canal × produit — taille du cercle proportionnelle à la prime moyenne")

    tmp = (panel.groupby(["canal","produit"], observed=True)
           .agg(nb=("resilie","count"),
                res=("resilie","sum"),
                prime=("prime_ttc","mean"))
           .assign(taux=lambda d: d["res"]/d["nb"]*100)
           .reset_index())

    taux_moy = tmp["taux"].mean()
    vol_moy  = tmp["nb"].mean()

    # Quadrants
    ax.axvline(taux_moy, color=MK_LGREY, linewidth=1.2, zorder=1)
    ax.axhline(vol_moy,  color=MK_LGREY, linewidth=1.2, zorder=1)

    # Labels quadrants
    for txt, xy, ha in [
        ("SURVEILLER\n(faible taux, fort vol.)", (taux_moy*0.5, vol_moy*1.4), "center"),
        ("PRIORITÉ ABSOLUE\n(fort taux, fort vol.)",  (taux_moy*1.5, vol_moy*1.4), "center"),
        ("STABLE\n(faible taux, faible vol.)", (taux_moy*0.5, vol_moy*0.55), "center"),
        ("OPTIMISER\n(fort taux, faible vol.)",  (taux_moy*1.5, vol_moy*0.55), "center"),
    ]:
        ax.text(xy[0], xy[1], txt, ha=ha, va="center", fontsize=8,
                color=MK_LGREY, style="italic", fontfamily="Georgia")

    # Bulles
    size_scale = 5000 / tmp["prime"].max()
    CC = [MK_NAVY, MK_BLUE, "#48CAE4", MK_ORANGE]
    canaux = tmp["canal"].unique()
    for j, canal in enumerate(canaux):
        sub = tmp[tmp["canal"]==canal]
        sc  = ax.scatter(sub["taux"], sub["nb"],
                         s=sub["prime"]*size_scale,
                         color=CC[j % len(CC)], alpha=0.75,
                         edgecolors=WHITE, linewidth=1.5,
                         label=canal, zorder=5)
        for _, row in sub.iterrows():
            ax.annotate(row["produit"],
                        xy=(row["taux"], row["nb"]),
                        xytext=(5, 4), textcoords="offset points",
                        fontsize=7.5, color=CC[j % len(CC)],
                        fontweight="bold", fontfamily="Georgia")

    ax.set_xlabel("Taux de résiliation (%)", fontsize=9, color=MK_GREY)
    ax.set_ylabel("Volume de contrats", fontsize=9, color=MK_GREY)
    ax.xaxis.set_major_formatter(mticker.FuncFormatter(lambda v,_: f"{v:.0f}%"))
    ax.yaxis.set_major_formatter(mticker.FuncFormatter(lambda v,_: f"{v:,.0f}"))
    ax.spines["top"].set_visible(False); ax.spines["right"].set_visible(False)
    ax.grid(color=MK_LGREY, linestyle="-", linewidth=0.4, alpha=0.6)

    # Légende taille bulle
    for pval, plabel in [(500,"Prime 500€"),(1000,"Prime 1000€"),(1500,"Prime 1500€")]:
        ax.scatter([], [], s=pval*size_scale, color=MK_LGREY, alpha=0.5,
                   edgecolors=WHITE, label=plabel)

    ax.legend(fontsize=8, loc="upper right",
              title="Canal / Prime moyenne", title_fontsize=8, frameon=False)
    section_label(ax, "Canal × Produit — Taux résiliation vs Volume (bulle = prime moyenne)")

    plt.savefig(OUT + "08_matrice_strategique.png")
    plt.close()
    print("✔ 08_matrice_strategique.png")

fig08_matrice_strategique(panel)


